---
import "../styles/admin.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const navItems = [
    { href: "/admin", label: "待审核", icon: "pending_actions" },
    { href: "/admin/published", label: "已发布", icon: "event_available" },
    { href: "/admin/offline", label: "已下线", icon: "event_busy" },
    { href: "/admin/tags", label: "标签归并", icon: "sell" }
];
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
            rel="stylesheet"
        />
        <title>{title} - Eventlist Admin</title>
    </head>
    <body>
        <div class="admin-shell">
            <nav class="admin-nav" aria-label="管理后台导航">
                <span class="admin-brand">
                    <span class="admin-brand-mark" aria-hidden="true">
                        <span class="material-symbols-rounded">admin_panel_settings</span>
                    </span>
                    <span>Eventlist 管理后台</span>
                </span>
                <ul class="admin-nav-list">
                    {
                        navItems.map((item) => (
                            <li>
                                <a
                                    class="admin-nav-link"
                                    href={item.href}
                                    aria-current={currentPath === item.href ? "page" : undefined}
                                >
                                    <span class="material-symbols-rounded" aria-hidden="true">
                                        {item.icon}
                                    </span>
                                    <span>{item.label}</span>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>
            <main class="admin-main">
                <header class="admin-topbar">
                    <h1 class="admin-title">{title}</h1>
                    {
                        Astro.locals.admin?.email ? (
                            <span class="status-chip">{Astro.locals.admin.email}</span>
                        ) : (
                            <span class="status-chip">admin</span>
                        )
                    }
                </header>
                <section class="admin-content">
                    <slot />
                </section>
            </main>
        </div>
    </body>
</html>
