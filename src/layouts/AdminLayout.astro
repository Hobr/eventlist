---
import ArrowUpRight from "@lucide/astro/icons/arrow-up-right";
import CircleCheck from "@lucide/astro/icons/circle-check";
import CircleOff from "@lucide/astro/icons/circle-off";
import Inbox from "@lucide/astro/icons/inbox";
import Plus from "@lucide/astro/icons/plus";
import Tags from "@lucide/astro/icons/tags";
import AdminMobileNav from "../components/admin/AdminMobileNav.svelte";
import { ADMIN_NAV_ITEMS, isAdminNavItemActive } from "../components/admin/navigation";
import "../styles/app.css";

interface Props {
    title: string;
    description?: string;
}

const { title, description = undefined } = Astro.props;
const currentPath = Astro.url.pathname;
const adminLabel =
    Astro.locals.admin?.email ??
    (Astro.locals.admin?.mode === "access" ? "Access 管理员" : "Token 管理员");
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="color-scheme" content="light dark" />
        <meta name="description" content={description ?? `${title} · 野活网管理后台`} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{title} - 野活网管理后台</title>
    </head>
    <body class="min-h-screen bg-background text-foreground">
        <div class="min-h-screen lg:grid lg:grid-cols-[15rem_minmax(0,1fr)]">
            <aside
                class="sticky top-0 hidden h-screen flex-col border-r border-border bg-surface lg:flex"
            >
                <a
                    href="/admin"
                    class="flex h-16 items-center border-b border-border px-5 focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none"
                >
                    <span>
                        <strong class="block text-sm text-foreground">野活网</strong>
                        <span class="block text-xs text-muted">管理工作台</span>
                    </span>
                </a>

                <nav class="flex flex-1 flex-col gap-1 p-3" aria-label="管理后台导航">
                    {
                        ADMIN_NAV_ITEMS.map((item) => (
                            <a
                                href={item.href}
                                aria-current={
                                    isAdminNavItemActive(currentPath, item.href)
                                        ? "page"
                                        : undefined
                                }
                                class:list={[
                                    "flex h-10 items-center gap-3 rounded-md px-3 text-sm font-semibold transition-colors focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none",
                                    isAdminNavItemActive(currentPath, item.href)
                                        ? "bg-primary-subtle text-primary-subtle-foreground"
                                        : "text-muted-foreground hover:bg-surface-subtle hover:text-foreground"
                                ]}
                            >
                                {item.kind === "pending" ? (
                                    <Inbox class="size-4" aria-hidden="true" />
                                ) : item.kind === "create" ? (
                                    <Plus class="size-4" aria-hidden="true" />
                                ) : item.kind === "published" ? (
                                    <CircleCheck class="size-4" aria-hidden="true" />
                                ) : item.kind === "offline" ? (
                                    <CircleOff class="size-4" aria-hidden="true" />
                                ) : (
                                    <Tags class="size-4" aria-hidden="true" />
                                )}
                                {item.label}
                            </a>
                        ))
                    }
                </nav>

                <div class="border-t border-border p-4">
                    <p class="truncate text-xs font-semibold text-muted">{adminLabel}</p>
                    <a
                        href="/"
                        class="mt-3 inline-flex items-center gap-1.5 text-xs font-semibold text-muted-foreground hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none"
                    >
                        查看公开站点
                        <ArrowUpRight class="size-3.5" aria-hidden="true" />
                    </a>
                </div>
            </aside>

            <div class="flex min-w-0 flex-col">
                <header
                    class="sticky top-0 z-30 flex h-14 items-center justify-between border-b border-border bg-background/95 px-4 backdrop-blur lg:hidden"
                >
                    <a
                        href="/admin"
                        class="flex min-w-0 items-center focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none"
                    >
                        <span class="truncate text-sm font-bold text-foreground">{title}</span>
                    </a>
                    <AdminMobileNav {currentPath} {title} {adminLabel} client:load />
                </header>

                <header
                    class="sticky top-0 z-20 hidden min-h-16 items-center justify-between border-b border-border bg-background/95 px-8 backdrop-blur lg:flex"
                >
                    <div class="py-3">
                        <h1 class="text-lg font-black text-foreground">{title}</h1>
                        {
                            description ? (
                                <p class="mt-0.5 text-xs text-muted-foreground">{description}</p>
                            ) : null
                        }
                    </div>
                    <span
                        class="rounded-full bg-surface-subtle px-3 py-1 text-xs font-semibold text-muted-foreground"
                    >
                        {adminLabel}
                    </span>
                </header>

                <main class="mx-auto w-full max-w-[96rem] flex-1 p-4 sm:p-6 lg:p-8">
                    <slot />
                </main>
            </div>
        </div>
    </body>
</html>
