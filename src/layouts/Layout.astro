---
import "../styles/public.css";

interface Props {
    title?: string;
    description?: string;
    jsonLd?: Record<string, unknown>;
}

const {
    title = "Eventlist",
    description = "面向普通爱好者的 ACG 活动查询与投稿目录。",
    jsonLd
} = Astro.props;
const currentPath = Astro.url.pathname;
const siteTitle = title === "Eventlist" ? title : `${title} - Eventlist`;
const navItems = [
    { href: "/", label: "首页" },
    { href: "/events", label: "活动" },
    { href: "/submit", label: "投稿" }
];

function isCurrent(href: string) {
    if (href === "/") return currentPath === "/";
    return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
            rel="stylesheet"
        />
        <title>{siteTitle}</title>
        {jsonLd ? <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /> : null}
    </head>
    <body>
        <div class="site-shell">
            <header class="site-header">
                <a class="site-brand" href="/">
                    <span class="site-brand-mark" aria-hidden="true">
                        <span class="material-symbols-rounded">explore</span>
                    </span>
                    <span>Eventlist</span>
                </a>
                <nav class="site-nav" aria-label="主导航">
                    {
                        navItems.map((item) => (
                            <a
                                href={item.href}
                                aria-current={isCurrent(item.href) ? "page" : undefined}
                            >
                                {item.label}
                            </a>
                        ))
                    }
                </nav>
            </header>
            <main class="site-main">
                <slot />
            </main>
        </div>
    </body>
</html>
