---
import Compass from "@lucide/astro/icons/compass";
import CalendarDays from "@lucide/astro/icons/calendar-days";
import GitFork from "@lucide/astro/icons/git-fork";
import Send from "@lucide/astro/icons/send";
import "../styles/app.css";

interface Props {
    title?: string;
    description?: string;
    jsonLd?: Record<string, unknown>;
}

const {
    title = "野活网",
    description = "浏览与投稿近期 ACG 活动的工具目录。",
    jsonLd
} = Astro.props;
const currentPath = Astro.url.pathname;
const siteTitle = title === "野活网" ? title : `${title} - 野活网`;

function isCurrent(href: string) {
    if (href === "/") return currentPath === "/";
    return currentPath === href || currentPath.startsWith(`${href}/`);
}

function navClasses(href: string) {
    return [
        "focus-visible:ring-ring/60 relative inline-flex h-12 items-center justify-center gap-2 px-3 text-sm font-semibold transition-colors focus-visible:ring-2 focus-visible:outline-none sm:h-16 sm:px-4",
        isCurrent(href)
            ? "text-primary after:bg-primary after:absolute after:inset-x-3 after:bottom-0 after:h-0.5"
            : "text-muted-foreground hover:text-foreground"
    ];
}
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="color-scheme" content="light dark" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{siteTitle}</title>
        {jsonLd ? <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /> : null}
    </head>
    <body class="min-h-screen border-t-4 border-primary bg-background text-foreground">
        <div class="flex min-h-screen flex-col">
            <header
                class="sticky top-0 z-40 border-b border-border bg-background/95 backdrop-blur-md"
            >
                <div
                    class="mx-auto flex w-full max-w-7xl flex-col px-4 sm:h-16 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8"
                >
                    <div class="flex h-14 items-center justify-between sm:h-auto">
                        <a
                            href="/"
                            class="inline-flex items-center font-bold text-foreground focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none"
                        >
                            <span class="flex flex-col leading-none">
                                <span class="text-base">野活网</span>
                                <span class="mt-1 text-[0.65rem] font-medium text-muted"
                                    >ACG 活动日历</span
                                >
                            </span>
                        </a>
                    </div>

                    <nav
                        class="grid grid-cols-3 border-t border-border sm:flex sm:border-t-0"
                        aria-label="主导航"
                    >
                        <a
                            href="/"
                            aria-current={isCurrent("/") ? "page" : undefined}
                            class:list={navClasses("/")}
                        >
                            <Compass class="size-4" aria-hidden="true" />
                            首页
                        </a>
                        <a
                            href="/events"
                            aria-current={isCurrent("/events") ? "page" : undefined}
                            class:list={navClasses("/events")}
                        >
                            <CalendarDays class="size-4" aria-hidden="true" />
                            活动
                        </a>
                        <a
                            href="/submit"
                            aria-current={isCurrent("/submit") ? "page" : undefined}
                            class:list={navClasses("/submit")}
                        >
                            <Send class="size-4" aria-hidden="true" />
                            投稿
                        </a>
                    </nav>
                </div>
            </header>

            <main class="mx-auto w-full max-w-7xl flex-1 px-4 py-7 sm:px-6 sm:py-10 lg:px-8">
                <slot />
            </main>

            <footer class="border-t border-border">
                <div
                    class="mx-auto flex min-h-16 w-full max-w-7xl flex-col justify-center gap-1 px-4 py-4 text-xs text-muted sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8"
                >
                    <span>野活网 · 已审核 ACG 活动目录</span>
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                        <span>按城市发现，按兴趣出发</span>
                        <a
                            href="https://github.com/Hobr/eventlist"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-1.5 font-semibold text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none"
                            aria-label="在 GitHub 上查看 Hobr/eventlist 项目并参与开发"
                        >
                            <GitFork class="size-3.5" aria-hidden="true" />
                            <span>GitHub.com/Hobr/eventlist</span>
                        </a>
                    </div>
                </div>
            </footer>
        </div>
    </body>
</html>
