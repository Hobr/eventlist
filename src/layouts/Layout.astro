---
import "../styles/app.css";

interface Props {
    title?: string;
    description?: string;
    jsonLd?: Record<string, unknown>;
}

const {
    title = "Eventlist",
    description = "浏览与投稿近期 ACG 活动的工具目录。",
    jsonLd
} = Astro.props;
const currentPath = Astro.url.pathname;
const siteTitle = title === "Eventlist" ? title : `${title} - Eventlist`;
const navItems = [
    { href: "/", label: "首页" },
    { href: "/events", label: "活动" },
    { href: "/submit", label: "投稿" }
];

function isCurrent(href: string) {
    if (href === "/") return currentPath === "/";
    return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{siteTitle}</title>
        {jsonLd ? <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /> : null}
    </head>
    <body class="bg-background text-foreground min-h-screen">
        <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-4 sm:px-6">
            <header class="border-border flex h-14 items-center gap-6 border-b">
                <a href="/" class="text-foreground flex items-center gap-2 text-base font-semibold">
                    <span
                        class="bg-primary text-primary-foreground inline-flex size-7 items-center justify-center rounded-md text-sm font-bold"
                        >E</span
                    >
                    Eventlist
                </a>
                <nav class="flex items-center gap-1" aria-label="主导航">
                    {
                        navItems.map((item) => (
                            <a
                                href={item.href}
                                aria-current={isCurrent(item.href) ? "page" : undefined}
                                class:list={[
                                    "rounded-md px-3 py-1.5 text-sm font-medium transition-colors",
                                    isCurrent(item.href)
                                        ? "bg-surface-subtle text-foreground"
                                        : "text-muted-foreground hover:bg-surface-subtle hover:text-foreground"
                                ]}
                            >
                                {item.label}
                            </a>
                        ))
                    }
                </nav>
            </header>

            <main class="flex-1 py-6 sm:py-8">
                <slot />
            </main>

            <footer class="border-border text-muted flex h-14 items-center border-t text-xs">
                <span>Eventlist · 已审核活动目录</span>
            </footer>
        </div>
    </body>
</html>
