---
import Base from "../../layouts/Base.astro";
import CopyButton from "../../components/CopyButton";
import PosterLightbox from "../../components/PosterLightbox";
import { getPosterUrl } from "../../lib/poster-url";
import { env } from "cloudflare:workers";

const { id } = Astro.params;
if (!id) return Astro.redirect("/");

const row = await env.DB.prepare(
  "SELECT * FROM events WHERE id = ? AND status = 'approved' AND deleted_at IS NULL"
)
  .bind(id)
  .first();

if (!row) return Astro.redirect("/");

const event = row as Record<string, unknown>;

const worksRows = await env.DB.prepare(
  "SELECT work_name FROM event_works WHERE event_id = ?"
)
  .bind(id)
  .all();
const works = (worksRows.results as Record<string, unknown>[]).map(
  (r) => r.work_name as string
);

const posterUrl = getPosterUrl(
  event.poster_key as string | null,
  env.PUBLIC_R2_BASE_URL ?? ""
);
const typeLabel = event.event_type === "doujin" ? "漫展" : "演唱会";
const dateStr = event.end_date
  ? `${event.start_date} ~ ${event.end_date}`
  : (event.start_date as string);
const siteUrl = env.PUBLIC_SITE_URL ?? "";
const ogImage = event.poster_key
  ? `${siteUrl}${posterUrl}`
  : undefined;
---

<Base
  title={`${event.title as string} - ACG 活动查询`}
  description={`查看活动详情：${event.title as string}，${dateStr}，${event.city as string} ${event.venue as string}`}
  ogImage={ogImage}
>
  <div class="mb-6">
    <a href="/" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-indigo-600 transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 19l-7-7 7-7" /></svg>
      返回活动列表
    </a>
  </div>

  <div class="card overflow-hidden">
    <div class="flex flex-col lg:flex-row">
      <div class="lg:w-80 flex-shrink-0 bg-slate-100 p-6 flex items-center justify-center">
        <PosterLightbox src={posterUrl} alt={event.title as string} client:load />
      </div>
      <div class="flex-1 p-6 lg:p-8">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h1 class="text-2xl font-bold text-slate-900 mb-2">{event.title as string}</h1>
            <div class="flex items-center gap-2">
              <span class={`badge ${event.event_type === "doujin" ? "badge-doujin" : "badge-concert"}`}>
                {typeLabel}
              </span>
              {event.scale && <span class="text-xs text-slate-400">{event.scale as string}</span>}
            </div>
          </div>
          <div class="flex items-center gap-1.5 text-sm text-slate-400 flex-shrink-0">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            {(event.view_count as number).toLocaleString()} 人关注
          </div>
        </div>

        <div class="space-y-4 mt-6">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <p class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-0.5">日期</p>
              <p class="text-sm text-slate-700">{dateStr}</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <p class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-0.5">地点</p>
              <p class="text-sm text-slate-700">{event.city as string} {event.venue as string}{event.address ? ` · ${event.address as string}` : ""}</p>
            </div>
          </div>

          {event.price_info && (
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-0.5">票价</p>
                <p class="text-sm text-slate-700">{event.price_info as string}</p>
              </div>
            </div>
          )}

          {event.ticket_url && (
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" /></svg>
              </div>
              <div>
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-0.5">购票</p>
                <a href={event.ticket_url as string} target="_blank" rel="noopener" class="btn-primary inline-block !text-xs !py-1.5 !px-3 mt-1">
                  前往购票 →
                </a>
              </div>
            </div>
          )}

          {event.qq_group && (
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
              </div>
              <div>
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-0.5">QQ 群</p>
                <div class="flex items-center gap-2">
                  <p class="text-sm text-slate-700 font-mono">{event.qq_group as string}</p>
                  <CopyButton text={event.qq_group as string} client:load />
                </div>
              </div>
            </div>
          )}

          {works.length > 0 && (
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
              </div>
              <div>
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-1.5">关联作品</p>
                <div class="flex flex-wrap gap-1.5">
                  {works.map((w) => (
                    <span class="badge bg-slate-100 text-slate-600">{w}</span>
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    {event.description && (
      <div class="border-t border-slate-100 p-6 lg:p-8">
        <h3 class="text-sm font-medium text-slate-900 mb-3">补充说明</h3>
        <p class="text-sm text-slate-600 whitespace-pre-wrap leading-relaxed">{event.description as string}</p>
      </div>
    )}
  </div>
</Base>

<script define:vars={{ id }}>
  fetch(`/api/events/${id}/view`, { method: "POST" }).catch(() => {});
</script>
