---
import ArrowLeft from "@lucide/astro/icons/arrow-left";
import CalendarDays from "@lucide/astro/icons/calendar-days";
import ExternalLink from "@lucide/astro/icons/external-link";
import MapPin from "@lucide/astro/icons/map-pin";
import Store from "@lucide/astro/icons/store";
import Ticket from "@lucide/astro/icons/ticket";
import EventArtwork from "../../components/EventArtwork.astro";
import Badge from "../../components/ui/badge.svelte";
import Layout from "../../layouts/Layout.astro";
import { getDB, STATUS } from "../../lib/db";
import { getPublicEvent } from "../../lib/db/queries";
import { getDivisionLabel } from "../../lib/divisions";
import { formatEventSchedule } from "../../lib/events/datetime";
import { getEventScaleLabel, getEventTypeLabel } from "../../lib/events/options";
import { getRuntimeEnv } from "../../lib/runtime/env";
import { buildEventJsonLd } from "../../lib/seo";

export const prerender = false;

const rawId = Astro.params.id ?? "";
const id = /^[1-9]\d*$/.test(rawId) ? Number(rawId) : Number.NaN;
let event = null;
let errorMessage = "";

try {
    if (!Number.isSafeInteger(id)) throw new Error("活动不存在");

    const db = await getDB(getRuntimeEnv());
    event = await getPublicEvent(db, id);
    if (!event) {
        Astro.response.status = 404;
        errorMessage = "活动不存在或尚未公开";
    }
} catch (error) {
    Astro.response.status = 404;
    errorMessage = error instanceof Error ? error.message : "活动不存在";
}

const tags = event?.tags ? event.tags.split("、").filter(Boolean) : [];
const divisionLabel = event ? getDivisionLabel(event.division_code) : null;
const canonicalUrl = new URL(Astro.url.pathname, Astro.url.origin).toString();
const jsonLd = event ? buildEventJsonLd(event, canonicalUrl) : undefined;
---

<Layout
    title={event?.title ?? "活动不存在"}
    description={event?.description ?? "活动不存在或尚未公开。"}
    jsonLd={jsonLd}
>
    {
        !event ? (
            <div class="border-y border-border py-14 text-center">
                <h1 class="text-2xl font-black text-foreground">{errorMessage}</h1>
                <a
                    href="/events"
                    class="mt-5 inline-flex h-10 items-center gap-2 rounded-md bg-foreground px-4 text-sm font-bold text-background"
                >
                    <ArrowLeft class="size-4" aria-hidden="true" />
                    返回活动列表
                </a>
            </div>
        ) : (
            <article class="flex flex-col gap-8">
                <a
                    href="/events"
                    class="inline-flex w-fit items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none"
                >
                    <ArrowLeft class="size-4" aria-hidden="true" />
                    活动列表
                </a>

                {event.status === STATUS.OFFLINE ? (
                    <div class="rounded-md bg-warning-subtle px-4 py-3 text-sm font-semibold text-warning">
                        该活动已下线，页面仅作为历史信息保留。
                    </div>
                ) : null}

                <header class="relative min-h-[25rem] overflow-hidden rounded-md sm:min-h-[34rem]">
                    <EventArtwork
                        src={event.cover_url}
                        alt={`${event.title} 封面`}
                        loading="eager"
                        fill
                        class="rounded-none"
                    />
                    <div class="absolute inset-0 bg-black/35" aria-hidden="true" />
                    <div class="absolute inset-x-0 bottom-0 bg-black/80 p-5 text-white sm:p-8">
                        <div class="flex flex-wrap gap-1.5">
                            <Badge tone="primary" class="border-white/15 bg-primary text-white">
                                {getEventTypeLabel(event.type)}
                            </Badge>
                            <Badge class="border-white/20 bg-black/35 text-white">
                                {getEventScaleLabel(event.scale)}
                            </Badge>
                        </div>
                        <h1 class="mt-4 max-w-4xl text-3xl leading-tight font-black sm:text-5xl">
                            {event.title}
                        </h1>
                        {tags.length > 0 ? (
                            <div class="mt-5 flex flex-wrap gap-2">
                                {tags.map((tag) => (
                                    <a
                                        href={`/events?tag=${encodeURIComponent(tag)}`}
                                        class="rounded-sm border border-white/25 bg-black/30 px-2.5 py-1 text-xs font-semibold text-white"
                                    >
                                        # {tag}
                                    </a>
                                ))}
                            </div>
                        ) : null}
                    </div>
                </header>

                <section class="grid border-y border-border sm:grid-cols-3" aria-label="活动信息">
                    <div class="flex gap-3 border-b border-border py-5 sm:border-r sm:border-b-0 sm:px-5 sm:first:pl-0">
                        <CalendarDays class="size-5 shrink-0 text-primary" aria-hidden="true" />
                        <div>
                            <p class="text-xs font-semibold text-muted">日期</p>
                            <strong class="mt-1 block text-sm text-foreground">
                                {formatEventSchedule(event)}
                            </strong>
                        </div>
                    </div>
                    <div class="flex gap-3 border-b border-border py-5 sm:border-r sm:border-b-0 sm:px-5">
                        <MapPin class="size-5 shrink-0 text-accent" aria-hidden="true" />
                        <div>
                            <p class="text-xs font-semibold text-muted">地区</p>
                            <strong class="mt-1 block text-sm text-foreground">
                                {divisionLabel ?? "未知地区"}
                            </strong>
                        </div>
                    </div>
                    <div class="flex gap-3 py-5 sm:px-5 sm:last:pr-0">
                        <Store class="size-5 shrink-0 text-warning" aria-hidden="true" />
                        <div>
                            <p class="text-xs font-semibold text-muted">场地</p>
                            <strong class="mt-1 block text-sm text-foreground">
                                {event.venue}
                            </strong>
                        </div>
                    </div>
                </section>

                <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_20rem]">
                    <section aria-labelledby="event-description-heading">
                        <h2
                            id="event-description-heading"
                            class="text-xl font-black text-foreground"
                        >
                            活动介绍
                        </h2>
                        {event.description ? (
                            <p class="mt-4 text-base leading-8 whitespace-pre-line text-foreground">
                                {event.description}
                            </p>
                        ) : (
                            <p class="mt-4 text-sm text-muted">暂无活动介绍。</p>
                        )}
                    </section>

                    <aside class="flex h-fit flex-col gap-4 border-t border-border pt-6 lg:border-t-0 lg:border-l lg:pt-0 lg:pl-7">
                        <h2 class="text-base font-black text-foreground">参加活动</h2>
                        {event.ticket_url ? (
                            <a
                                href={event.ticket_url}
                                target="_blank"
                                rel="nofollow noopener noreferrer"
                                class="inline-flex h-11 items-center justify-center gap-2 rounded-md bg-primary px-4 text-sm font-bold text-primary-foreground"
                            >
                                <Ticket class="size-4" aria-hidden="true" />
                                查看购票页
                            </a>
                        ) : null}
                        <a
                            href={event.source_url}
                            target="_blank"
                            rel="nofollow noopener noreferrer"
                            class="inline-flex h-11 items-center justify-center gap-2 rounded-md border border-border-strong bg-surface px-4 text-sm font-bold text-foreground"
                        >
                            <ExternalLink class="size-4" aria-hidden="true" />
                            活动来源
                        </a>
                        <dl class="mt-2 flex flex-col gap-4 border-t border-border pt-5 text-sm">
                            <div>
                                <dt class="text-xs font-semibold text-muted">详细地址</dt>
                                <dd class="mt-1 text-foreground">{event.address ?? "未填写"}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-semibold text-muted">官方交流群</dt>
                                <dd class="mt-1 text-foreground">{event.qq_group ?? "未填写"}</dd>
                            </div>
                        </dl>
                    </aside>
                </div>
            </article>
        )
    }
</Layout>
