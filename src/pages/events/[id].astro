---
import Layout from "../../layouts/Layout.astro";
import Badge from "../../components/ui/badge.svelte";
import { getDB, STATUS } from "../../lib/db";
import { getPublicEvent } from "../../lib/db/queries";
import { getRuntimeEnv } from "../../lib/runtime/env";
import { buildEventJsonLd } from "../../lib/seo";
import { getDivisionLabel } from "../../lib/divisions";
import CalendarDays from "@lucide/svelte/icons/calendar-days";
import MapPin from "@lucide/svelte/icons/map-pin";
import Store from "@lucide/svelte/icons/store";
import Ticket from "@lucide/svelte/icons/ticket";
import ExternalLink from "@lucide/svelte/icons/external-link";

export const prerender = false;

const id = Number.parseInt(Astro.params.id ?? "", 10);
let event = null;
let errorMessage = "";

try {
    if (!Number.isInteger(id) || id <= 0) {
        throw new Error("活动不存在");
    }

    const db = await getDB(getRuntimeEnv());
    event = await getPublicEvent(db, id);
    if (!event) {
        Astro.response.status = 404;
        errorMessage = "活动不存在或尚未公开";
    }
} catch (error) {
    Astro.response.status = 404;
    errorMessage = error instanceof Error ? error.message : "活动不存在";
}

const tags = event?.tags ? event.tags.split("、").filter(Boolean) : [];
const divisionLabel = event ? getDivisionLabel(event.division_code) : null;
const canonicalUrl = new URL(Astro.url.pathname, Astro.url.origin).toString();
const jsonLd = event ? buildEventJsonLd(event, canonicalUrl) : undefined;
---

<Layout
    title={event?.title ?? "活动不存在"}
    description={event?.description ?? "活动不存在或尚未公开。"}
    jsonLd={jsonLd}
>
    {
        !event ? (
            <div class="border-border bg-surface text-danger rounded-md border p-8 text-center text-sm font-semibold">
                {errorMessage}
            </div>
        ) : (
            <article class="flex flex-col gap-6">
                <header class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                    <div class="flex min-w-0 flex-col gap-3">
                        <div class="flex flex-wrap items-center gap-1.5">
                            <Badge tone="accent">{event.type_label ?? event.type}</Badge>
                            <Badge>{event.scale_label ?? event.scale}</Badge>
                            {tags.map((tag) => (
                                <a href={`/events?tag=${encodeURIComponent(tag)}`}>
                                    <Badge>{tag}</Badge>
                                </a>
                            ))}
                        </div>
                        <h1 class="text-foreground text-2xl font-semibold">{event.title}</h1>
                        {event.status === STATUS.OFFLINE ? (
                            <div class="border-border bg-surface-subtle text-muted-foreground rounded-md border p-3 text-sm">
                                该活动已下线，页面仅作为历史信息保留。
                            </div>
                        ) : null}
                    </div>
                    {event.cover_url ? (
                        <img
                            src={event.cover_url}
                            alt={`${event.title} 封面`}
                            class="border-border aspect-[16/9] w-full max-w-md rounded-md border object-cover"
                        />
                    ) : null}
                </header>

                <div class="grid gap-4 lg:grid-cols-3">
                    <section class="flex flex-col gap-4 lg:col-span-2">
                        <div class="grid gap-3 sm:grid-cols-3">
                            <div class="border-border bg-surface flex items-start gap-3 rounded-md border p-4">
                                <CalendarDays
                                    class="text-muted size-5 shrink-0"
                                    aria-hidden="true"
                                />
                                <div class="min-w-0">
                                    <small class="text-muted-foreground block text-xs">时间</small>
                                    <strong class="text-foreground block text-sm">
                                        {event.start_date} - {event.end_date}
                                    </strong>
                                </div>
                            </div>
                            <div class="border-border bg-surface flex items-start gap-3 rounded-md border p-4">
                                <MapPin class="text-muted size-5 shrink-0" aria-hidden="true" />
                                <div class="min-w-0">
                                    <small class="text-muted-foreground block text-xs">地区</small>
                                    <strong class="text-foreground block text-sm">
                                        {divisionLabel ?? "未知地区"}
                                    </strong>
                                </div>
                            </div>
                            <div class="border-border bg-surface flex items-start gap-3 rounded-md border p-4">
                                <Store class="text-muted size-5 shrink-0" aria-hidden="true" />
                                <div class="min-w-0">
                                    <small class="text-muted-foreground block text-xs">地点</small>
                                    <strong class="text-foreground block text-sm">
                                        {event.venue}
                                    </strong>
                                </div>
                            </div>
                        </div>

                        <div class="border-border bg-surface rounded-md border p-5">
                            <p class="text-muted-foreground text-xs font-semibold">活动介绍</p>
                            {event.description ? (
                                <p class="text-foreground mt-2 text-sm leading-relaxed">
                                    {event.description}
                                </p>
                            ) : (
                                <p class="text-muted mt-2 text-sm">暂无活动介绍。</p>
                            )}
                        </div>
                    </section>

                    <aside class="border-border bg-surface flex h-fit flex-col gap-3 rounded-md border p-5">
                        <p class="text-muted-foreground text-xs font-semibold">操作</p>
                        {event.ticket_url ? (
                            <a
                                href={event.ticket_url}
                                rel="nofollow noopener noreferrer"
                                class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-10 items-center justify-center gap-2 rounded-md px-4 text-sm font-semibold transition-colors"
                            >
                                <Ticket class="size-4" aria-hidden="true" />
                                查看购票页
                            </a>
                        ) : null}
                        <a
                            href={event.source_url}
                            rel="nofollow noopener noreferrer"
                            class="border-border-strong bg-surface text-foreground hover:bg-surface-subtle inline-flex h-10 items-center justify-center gap-2 rounded-md border px-4 text-sm font-semibold transition-colors"
                        >
                            <ExternalLink class="size-4" aria-hidden="true" />
                            来源链接
                        </a>
                        <dl class="border-border mt-2 flex flex-col gap-2 border-t pt-3 text-sm">
                            <div class="flex flex-col gap-0.5">
                                <dt class="text-muted-foreground text-xs">地址</dt>
                                <dd class="text-foreground">{event.address ?? "未填写"}</dd>
                            </div>
                            <div class="flex flex-col gap-0.5">
                                <dt class="text-muted-foreground text-xs">官方交流群</dt>
                                <dd class="text-foreground">{event.qq_group ?? "未填写"}</dd>
                            </div>
                        </dl>
                    </aside>
                </div>
            </article>
        )
    }
</Layout>
