---
import Layout from "../../layouts/Layout.astro";
import { getDB, STATUS } from "../../lib/db";
import { getPublicEvent } from "../../lib/db/queries";
import { getRuntimeEnv } from "../../lib/runtime/env";
import { buildEventJsonLd } from "../../lib/seo";
import { getDivisionLabel } from "../../lib/divisions";

export const prerender = false;

const id = Number.parseInt(Astro.params.id ?? "", 10);
let event = null;
let errorMessage = "";

try {
    if (!Number.isInteger(id) || id <= 0) {
        throw new Error("活动不存在");
    }

    const db = await getDB(getRuntimeEnv());
    event = await getPublicEvent(db, id);
    if (!event) {
        Astro.response.status = 404;
        errorMessage = "活动不存在或尚未公开";
    }
} catch (error) {
    Astro.response.status = 404;
    errorMessage = error instanceof Error ? error.message : "活动不存在";
}

const tags = event?.tags ? event.tags.split("、").filter(Boolean) : [];
const divisionLabel = event ? getDivisionLabel(event.division_code) : null;
const canonicalUrl = new URL(Astro.url.pathname, Astro.url.origin).toString();
const jsonLd = event ? buildEventJsonLd(event, canonicalUrl) : undefined;
---

<Layout
    title={event?.title ?? "活动不存在"}
    description={event?.description ?? "活动不存在或尚未公开。"}
    jsonLd={jsonLd}
>
    <section class="page-section">
        <div class="section-inner">
            {
                !event ? (
                    <div class="panel empty-state error-text">{errorMessage}</div>
                ) : (
                    <article class="event-dossier">
                        <header class="dossier-hero">
                            <div class="dossier-copy">
                                <p class="section-kicker">EVENT DOSSIER</p>
                                <h1>{event.title}</h1>
                                <div class="chip-row">
                                    <span class="chip" data-tone="accent">
                                        {event.type_label ?? event.type}
                                    </span>
                                    <span class="chip">{event.scale_label ?? event.scale}</span>
                                    {tags.map((tag) => (
                                        <a
                                            class="chip"
                                            href={`/events?tag=${encodeURIComponent(tag)}`}
                                        >
                                            {tag}
                                        </a>
                                    ))}
                                </div>
                            </div>
                            {event.status === STATUS.OFFLINE ? (
                                <div class="notice">该活动已下线，页面仅作为历史信息保留。</div>
                            ) : null}
                            {event.cover_url ? (
                                <img
                                    class="dossier-cover"
                                    src={event.cover_url}
                                    alt={`${event.title} 封面`}
                                />
                            ) : (
                                <div class="dossier-cover" aria-hidden="true" />
                            )}
                        </header>

                        <div class="dossier-grid">
                            <section class="dossier-main">
                                <div class="fact-grid">
                                    <div class="fact-tile">
                                        <span class="material-symbols-rounded" aria-hidden="true">
                                            calendar_month
                                        </span>
                                        <small>时间</small>
                                        <strong>
                                            {event.start_date} - {event.end_date}
                                        </strong>
                                    </div>
                                    <div class="fact-tile">
                                        <span class="material-symbols-rounded" aria-hidden="true">
                                            location_on
                                        </span>
                                        <small>地区</small>
                                        <strong>{divisionLabel ?? "未知地区"}</strong>
                                    </div>
                                    <div class="fact-tile">
                                        <span class="material-symbols-rounded" aria-hidden="true">
                                            store
                                        </span>
                                        <small>地点</small>
                                        <strong>{event.venue}</strong>
                                    </div>
                                </div>

                                <div class="panel description-panel">
                                    <p class="section-kicker">DESCRIPTION</p>
                                    {event.description ? (
                                        <p class="description-text">{event.description}</p>
                                    ) : (
                                        <p class="muted">暂无活动介绍。</p>
                                    )}
                                </div>
                            </section>

                            <aside class="panel dossier-actions">
                                <p class="section-kicker">ACTIONS</p>
                                {event.ticket_url ? (
                                    <a
                                        class="button button-filled"
                                        href={event.ticket_url}
                                        rel="nofollow noopener noreferrer"
                                    >
                                        <span class="material-symbols-rounded" aria-hidden="true">
                                            confirmation_number
                                        </span>
                                        查看购票页
                                    </a>
                                ) : null}
                                <a
                                    class="button button-outline"
                                    href={event.source_url}
                                    rel="nofollow noopener noreferrer"
                                >
                                    <span class="material-symbols-rounded" aria-hidden="true">
                                        open_in_new
                                    </span>
                                    来源链接
                                </a>
                                <dl class="meta-list">
                                    <div>
                                        <dt>地址</dt>
                                        <dd>{event.address ?? "未填写"}</dd>
                                    </div>
                                    <div>
                                        <dt>官方交流群</dt>
                                        <dd>{event.qq_group ?? "未填写"}</dd>
                                    </div>
                                </dl>
                            </aside>
                        </div>
                    </article>
                )
            }
        </div>
    </section>
</Layout>
