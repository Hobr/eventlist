---
import ChevronLeft from "@lucide/svelte/icons/chevron-left";
import ChevronRight from "@lucide/svelte/icons/chevron-right";
import FilterBar from "../../components/FilterBar.svelte";
import EventCard from "../../components/EventCard.astro";
import Layout from "../../layouts/Layout.astro";
import { getDB } from "../../lib/db";
import {
    listPublishedEvents,
    listScales,
    listTypes,
    topTags,
    type EventSort,
    type PublishedEventFilters
} from "../../lib/db/queries";
import { isRegionCode } from "../../lib/divisions";
import { getRuntimeEnv } from "../../lib/runtime/env";

export const prerender = false;

function parsePositiveInt(value: string | null) {
    const numberValue = Number.parseInt(value ?? "", 10);
    return Number.isInteger(numberValue) && numberValue > 0 ? numberValue : undefined;
}

function parseDivisionCode(value: string | null) {
    return value && isRegionCode(value) ? value : undefined;
}

function parseDate(value: string | null) {
    return value && /^\d{4}-\d{2}-\d{2}$/.test(value) ? value : undefined;
}

function parseSort(value: string | null): EventSort {
    return value === "start_desc" ? "start_desc" : "start_asc";
}

function nextHref(page: number) {
    const searchParams = new URLSearchParams(Astro.url.searchParams);
    searchParams.set("page", String(page));
    const query = searchParams.toString();
    return query ? `/events?${query}` : "/events";
}

const filters: PublishedEventFilters = {
    divisionCode: parseDivisionCode(Astro.url.searchParams.get("city")),
    type: Astro.url.searchParams.get("type") || undefined,
    scale: Astro.url.searchParams.get("scale") || undefined,
    tag: Astro.url.searchParams.get("tag") || undefined,
    from: parseDate(Astro.url.searchParams.get("from")),
    to: parseDate(Astro.url.searchParams.get("to")),
    page: parsePositiveInt(Astro.url.searchParams.get("page")) ?? 1,
    pageSize: 20,
    sort: parseSort(Astro.url.searchParams.get("sort"))
};

let types = [];
let scales = [];
let tags = [];
let events = [];
let hasNext = false;
let errorMessage = "";

try {
    const db = await getDB(getRuntimeEnv());
    const [loadedTypes, loadedScales, loadedTags, page] = await Promise.all([
        listTypes(db),
        listScales(db),
        topTags(db, 20),
        listPublishedEvents(db, filters)
    ]);

    types = loadedTypes;
    scales = loadedScales;
    tags = loadedTags;
    events = page.events;
    hasNext = page.hasNext;
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载活动列表";
}
---

<Layout title="活动列表" description="筛选近期已发布且未结束的 ACG 活动。">
    <div class="flex flex-col gap-8">
        <header
            class="border-border flex flex-col gap-4 border-b pb-6 sm:flex-row sm:items-end sm:justify-between"
        >
            <div>
                <p class="text-accent text-sm font-bold">已发布 · 未结束</p>
                <h1 class="text-foreground mt-2 text-3xl font-black sm:text-4xl">活动列表</h1>
            </div>
            <div class="flex items-center gap-3">
                <strong class="text-foreground text-2xl font-black">{events.length}</strong>
                <span class="text-muted max-w-20 text-xs leading-tight">本页活动</span>
            </div>
        </header>

        <FilterBar types={types} scales={scales} tags={tags} filters={filters} client:load />

        {
            errorMessage ? (
                <div
                    class="bg-danger-subtle text-danger rounded-md p-5 text-sm font-semibold"
                    role="alert"
                >
                    {errorMessage}
                </div>
            ) : events.length > 0 ? (
                <>
                    <section aria-label="活动结果" class="border-border border-t">
                        {events.map((event) => (
                            <EventCard event={event} variant="row" />
                        ))}
                    </section>
                    <nav
                        class="text-muted flex items-center justify-center gap-3 py-4 text-sm"
                        aria-label="活动分页"
                    >
                        {filters.page && filters.page > 1 ? (
                            <a
                                class="border-border-strong bg-surface text-foreground hover:bg-surface-subtle inline-flex h-9 items-center gap-1.5 rounded-md border px-3 text-xs font-semibold"
                                href={nextHref(filters.page - 1)}
                            >
                                <ChevronLeft class="size-4" aria-hidden="true" />
                                上一页
                            </a>
                        ) : null}
                        <span class="text-muted-foreground font-medium">第 {filters.page} 页</span>
                        {hasNext ? (
                            <a
                                class="border-border-strong bg-surface text-foreground hover:bg-surface-subtle inline-flex h-9 items-center gap-1.5 rounded-md border px-3 text-xs font-semibold"
                                href={nextHref((filters.page ?? 1) + 1)}
                            >
                                下一页
                                <ChevronRight class="size-4" aria-hidden="true" />
                            </a>
                        ) : null}
                    </nav>
                </>
            ) : (
                <div class="border-border border-y py-12 text-center">
                    <h2 class="text-foreground text-xl font-bold">没有匹配的近期活动</h2>
                    <p class="text-muted-foreground mt-2 text-sm">尝试移除部分筛选条件。</p>
                    <a
                        href="/events"
                        class="bg-foreground text-background mt-5 inline-flex h-10 items-center rounded-md px-4 text-sm font-bold"
                    >
                        重置筛选
                    </a>
                </div>
            )
        }
    </div>
</Layout>
