---
import FilterBar from "../../components/FilterBar.svelte";
import EventCard from "../../components/EventCard.astro";
import Layout from "../../layouts/Layout.astro";
import { getDB } from "../../lib/db";
import {
    listPublishedEvents,
    listScales,
    listTypes,
    topTags,
    type EventSort,
    type PublishedEventFilters
} from "../../lib/db/queries";
import { isRegionCode } from "../../lib/divisions";
import { getRuntimeEnv } from "../../lib/runtime/env";

export const prerender = false;

function parsePositiveInt(value: string | null) {
    const numberValue = Number.parseInt(value ?? "", 10);
    return Number.isInteger(numberValue) && numberValue > 0 ? numberValue : undefined;
}

function parseDivisionCode(value: string | null) {
    return value && isRegionCode(value) ? value : undefined;
}

function parseDate(value: string | null) {
    return value && /^\d{4}-\d{2}-\d{2}$/.test(value) ? value : undefined;
}

function parseSort(value: string | null): EventSort {
    return value === "start_desc" ? "start_desc" : "start_asc";
}

function nextHref(page: number) {
    const searchParams = new URLSearchParams(Astro.url.searchParams);
    searchParams.set("page", String(page));
    const query = searchParams.toString();
    return query ? `/events?${query}` : "/events";
}

const filters: PublishedEventFilters = {
    divisionCode: parseDivisionCode(Astro.url.searchParams.get("city")),
    type: Astro.url.searchParams.get("type") || undefined,
    scale: Astro.url.searchParams.get("scale") || undefined,
    tag: Astro.url.searchParams.get("tag") || undefined,
    from: parseDate(Astro.url.searchParams.get("from")),
    to: parseDate(Astro.url.searchParams.get("to")),
    page: parsePositiveInt(Astro.url.searchParams.get("page")) ?? 1,
    pageSize: 20,
    sort: parseSort(Astro.url.searchParams.get("sort"))
};

let types = [];
let scales = [];
let tags = [];
let events = [];
let hasNext = false;
let errorMessage = "";

try {
    const db = await getDB(getRuntimeEnv());
    const [loadedTypes, loadedScales, loadedTags, page] = await Promise.all([
        listTypes(db),
        listScales(db),
        topTags(db, 20),
        listPublishedEvents(db, filters)
    ]);

    types = loadedTypes;
    scales = loadedScales;
    tags = loadedTags;
    events = page.events;
    hasNext = page.hasNext;
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载活动列表";
}
---

<Layout title="活动列表" description="筛选近期已发布且未结束的 ACG 活动。">
    <section class="page-section browse-section">
        <div class="section-inner browse-shell">
            <aside class="browse-sidebar">
                <FilterBar
                    types={types}
                    scales={scales}
                    tags={tags}
                    filters={filters}
                    client:load
                />
            </aside>

            <div class="browse-main">
                <div class="browse-header">
                    <div>
                        <p class="section-kicker">EVENTS</p>
                        <h1>活动雷达</h1>
                        <p class="supporting-copy">
                            当前视图保留在地址栏，可直接收藏或分享。列表以时间线方式展示，方便连续浏览。
                        </p>
                    </div>
                    <div class="browse-count">
                        <span>{events.length}</span>
                        <small>本页活动</small>
                    </div>
                </div>
                <div class="browse-modebar" aria-label="浏览模式">
                    <span class="mode-pill" data-active="true">
                        <span class="material-symbols-rounded" aria-hidden="true"
                            >view_timeline</span
                        >
                        时间线
                    </span>
                    <span class="mode-pill">
                        <span class="material-symbols-rounded" aria-hidden="true">link</span>
                        URL 可分享
                    </span>
                    <span class="mode-pill">
                        <span class="material-symbols-rounded" aria-hidden="true">verified</span>
                        已审核
                    </span>
                </div>
                {
                    errorMessage ? (
                        <div class="notice error">{errorMessage}</div>
                    ) : events.length > 0 ? (
                        <>
                            <div class="event-feed">
                                {events.map((event) => (
                                    <EventCard event={event} variant="row" />
                                ))}
                            </div>
                            <nav class="pagination" aria-label="活动分页">
                                {filters.page && filters.page > 1 ? (
                                    <a
                                        class="button button-outline"
                                        href={nextHref(filters.page - 1)}
                                    >
                                        <span class="material-symbols-rounded" aria-hidden="true">
                                            chevron_left
                                        </span>
                                        上一页
                                    </a>
                                ) : null}
                                <span class="muted">第 {filters.page} 页</span>
                                {hasNext ? (
                                    <a
                                        class="button button-outline"
                                        href={nextHref((filters.page ?? 1) + 1)}
                                    >
                                        下一页
                                        <span class="material-symbols-rounded" aria-hidden="true">
                                            chevron_right
                                        </span>
                                    </a>
                                ) : null}
                            </nav>
                        </>
                    ) : (
                        <div class="panel empty-state">没有匹配的近期活动。</div>
                    )
                }
            </div>
        </div>
    </section>
</Layout>
