---
import ChevronLeft from "@lucide/astro/icons/chevron-left";
import ChevronRight from "@lucide/astro/icons/chevron-right";
import FilterBar from "../../components/FilterBar.svelte";
import EventCard from "../../components/EventCard.astro";
import Layout from "../../layouts/Layout.astro";
import { getDB } from "../../lib/db";
import {
    listPublishedEvents,
    topTags,
    type EventSort,
    type EventTiming,
    type PublishedEventFilters
} from "../../lib/db/queries";
import { isRegionCode } from "../../lib/divisions";
import { EVENT_SCALES, EVENT_TYPES } from "../../lib/events/options";
import { getRuntimeEnv } from "../../lib/runtime/env";

export const prerender = false;

function parsePositiveInt(value: string | null) {
    const numberValue = Number.parseInt(value ?? "", 10);
    return Number.isInteger(numberValue) && numberValue > 0 ? numberValue : undefined;
}

function parseDivisionCode(value: string | null) {
    return value && isRegionCode(value) ? value : undefined;
}

function parseDate(value: string | null) {
    return value && /^\d{4}-\d{2}-\d{2}$/.test(value) ? value : undefined;
}

function parseTiming(value: string | null): EventTiming {
    return value === "ended" || value === "all" ? value : "upcoming";
}

function parseSort(value: string | null): EventSort | undefined {
    return value === "start_asc" || value === "start_desc" || value === "end_desc"
        ? value
        : undefined;
}

function nextHref(page: number) {
    const searchParams = new URLSearchParams(Astro.url.searchParams);
    searchParams.set("page", String(page));
    const query = searchParams.toString();
    return query ? `/events?${query}` : "/events";
}

const filters: PublishedEventFilters = {
    timing: parseTiming(Astro.url.searchParams.get("status")),
    divisionCode: parseDivisionCode(Astro.url.searchParams.get("city")),
    type: Astro.url.searchParams.get("type") || undefined,
    scale: Astro.url.searchParams.get("scale") || undefined,
    tag: Astro.url.searchParams.get("tag") || undefined,
    from: parseDate(Astro.url.searchParams.get("from")),
    to: parseDate(Astro.url.searchParams.get("to")),
    page: parsePositiveInt(Astro.url.searchParams.get("page")) ?? 1,
    pageSize: 20,
    sort: parseSort(Astro.url.searchParams.get("sort"))
};

const timingCopy = {
    upcoming: {
        description: "筛选近期已发布且未结束的 ACG 活动。",
        kicker: "已发布 · 未结束",
        emptyTitle: "没有匹配的近期活动"
    },
    ended: {
        description: "查询已发布且已经结束的 ACG 活动。",
        kicker: "已发布 · 已结束",
        emptyTitle: "没有匹配的已结束活动"
    },
    all: {
        description: "查询全部已发布的 ACG 活动。",
        kicker: "已发布 · 全部",
        emptyTitle: "没有匹配的活动"
    }
}[filters.timing ?? "upcoming"];

const types = EVENT_TYPES;
const scales = EVENT_SCALES;
let tags = [];
let events = [];
let hasNext = false;
let errorMessage = "";

try {
    const db = await getDB(getRuntimeEnv());
    const [loadedTags, page] = await Promise.all([
        topTags(db, 20),
        listPublishedEvents(db, filters)
    ]);

    tags = loadedTags;
    events = page.events;
    hasNext = page.hasNext;
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载活动列表";
}
---

<Layout title="活动列表" description={timingCopy.description}>
    <div class="flex flex-col gap-8">
        <header
            class="flex flex-col gap-4 border-b border-border pb-6 sm:flex-row sm:items-end sm:justify-between"
        >
            <div>
                <p class="text-sm font-bold text-accent">{timingCopy.kicker}</p>
                <h1 class="mt-2 text-3xl font-black text-foreground sm:text-4xl">活动列表</h1>
            </div>
            <div class="flex items-center gap-3">
                <strong class="text-2xl font-black text-foreground">{events.length}</strong>
                <span class="max-w-20 text-xs leading-tight text-muted">本页活动</span>
            </div>
        </header>

        <FilterBar types={types} scales={scales} tags={tags} filters={filters} client:load />

        {
            errorMessage ? (
                <div
                    class="rounded-md bg-danger-subtle p-5 text-sm font-semibold text-danger"
                    role="alert"
                >
                    {errorMessage}
                </div>
            ) : events.length > 0 ? (
                <>
                    <section aria-label="活动结果" class="border-t border-border">
                        {events.map((event, index) => (
                            <EventCard event={event} variant="row" priority={index < 3} />
                        ))}
                    </section>
                    <nav
                        class="flex items-center justify-center gap-3 py-4 text-sm text-muted"
                        aria-label="活动分页"
                    >
                        {filters.page && filters.page > 1 ? (
                            <a
                                class="inline-flex h-9 items-center gap-1.5 rounded-md border border-border-strong bg-surface px-3 text-xs font-semibold text-foreground hover:bg-surface-subtle"
                                href={nextHref(filters.page - 1)}
                            >
                                <ChevronLeft class="size-4" aria-hidden="true" />
                                上一页
                            </a>
                        ) : null}
                        <span class="font-medium text-muted-foreground">第 {filters.page} 页</span>
                        {hasNext ? (
                            <a
                                class="inline-flex h-9 items-center gap-1.5 rounded-md border border-border-strong bg-surface px-3 text-xs font-semibold text-foreground hover:bg-surface-subtle"
                                href={nextHref((filters.page ?? 1) + 1)}
                            >
                                下一页
                                <ChevronRight class="size-4" aria-hidden="true" />
                            </a>
                        ) : null}
                    </nav>
                </>
            ) : (
                <div class="border-y border-border py-12 text-center">
                    <h2 class="text-xl font-bold text-foreground">{timingCopy.emptyTitle}</h2>
                    <p class="mt-2 text-sm text-muted-foreground">尝试移除部分筛选条件。</p>
                    <a
                        href="/events"
                        class="mt-5 inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-bold text-background"
                    >
                        重置筛选
                    </a>
                </div>
            )
        }
    </div>
</Layout>
