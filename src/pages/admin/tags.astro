---
import TagMergeForm from "../../components/admin/TagMergeForm.svelte";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listTags } from "../../lib/db/queries";
import { getDB } from "../../lib/db";
import { getRuntimeEnv } from "../../lib/runtime/env";

export const prerender = false;

let tags = [];
let errorMessage = "";

try {
    const db = await getDB(getRuntimeEnv());
    tags = await listTags(db);
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载标签";
}

const tagOptions = tags.map((tag) => ({
    value: String(tag.id),
    label: `${tag.name} (${tag.event_count})`
}));
---

<AdminLayout title="标签归并" description="将重复标签合并到统一名称，保持活动检索整洁。">
    {
        errorMessage ? (
            <div
                class="rounded-md border border-danger/25 bg-danger-subtle p-6 text-center text-sm font-semibold text-danger"
                role="alert"
            >
                {errorMessage}
            </div>
        ) : (
            <div class="flex flex-col gap-8">
                <section class="border-b border-border pb-8" aria-labelledby="merge-heading">
                    <div class="mb-5">
                        <h2 id="merge-heading" class="text-base font-black text-foreground">
                            归并重复标签
                        </h2>
                        <p class="mt-1 text-sm text-muted-foreground">
                            源标签会被移除，关联活动将改用目标标签。
                        </p>
                    </div>
                    <TagMergeForm options={tagOptions} client:load />
                </section>

                <section aria-labelledby="tag-inventory-heading">
                    <div class="mb-4 flex items-end justify-between gap-4">
                        <div>
                            <h2
                                id="tag-inventory-heading"
                                class="text-base font-black text-foreground"
                            >
                                标签目录
                            </h2>
                            <p class="mt-1 text-sm text-muted-foreground">
                                当前共 {tags.length} 个规范标签
                            </p>
                        </div>
                    </div>

                    {tags.length > 0 ? (
                        <div class="divide-y divide-border border-y border-border">
                            {tags.map((tag) => (
                                <div class="flex items-center justify-between gap-4 py-3">
                                    <div class="min-w-0">
                                        <p class="truncate text-sm font-bold text-foreground">
                                            {tag.name}
                                        </p>
                                        <p class="mt-0.5 text-xs text-muted">标签 #{tag.id}</p>
                                    </div>
                                    <span class="shrink-0 rounded-full bg-surface-subtle px-2.5 py-1 text-xs font-semibold text-muted-foreground">
                                        {tag.event_count} 个活动
                                    </span>
                                </div>
                            ))}
                        </div>
                    ) : (
                        <div class="rounded-md border border-border p-8 text-center text-sm text-muted-foreground">
                            暂无标签。
                        </div>
                    )}
                </section>
            </div>
        )
    }
</AdminLayout>
