---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SelectField from "../../components/SelectField.svelte";
import { listTags } from "../../lib/db/queries";
import { getDB } from "../../lib/db";
import { getRuntimeEnv } from "../../lib/runtime/env";

export const prerender = false;

let tags = [];
let errorMessage = "";

try {
    const db = await getDB(getRuntimeEnv());
    tags = await listTags(db);
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载标签";
}

const tagOptions = tags.map((tag) => ({
    value: String(tag.id),
    label: `${tag.name} (${tag.event_count})`
}));
---

<AdminLayout title="标签归并">
    {
        errorMessage ? (
            <div class="border-border bg-surface text-danger rounded-md border p-6 text-center text-sm font-semibold">
                {errorMessage}
            </div>
        ) : (
            <div class="flex flex-col gap-6">
                <div class="border-border bg-surface rounded-md border p-5">
                    <form id="merge-tags-form" class="grid gap-4 sm:grid-cols-3">
                        <SelectField
                            name="from"
                            label="源标签"
                            options={tagOptions}
                            placeholder="选择要归并的标签"
                            required
                            client:load
                        />
                        <SelectField
                            name="to"
                            label="目标标签"
                            options={tagOptions}
                            placeholder="选择规范标签"
                            required
                            client:load
                        />
                        <div class="flex items-end">
                            <button
                                class="bg-danger text-danger-foreground hover:bg-danger/90 inline-flex h-10 w-full items-center justify-center rounded-md px-4 text-sm font-semibold transition-colors"
                                type="submit"
                            >
                                归并
                            </button>
                        </div>
                    </form>
                </div>

                <div class="border-border bg-surface overflow-x-auto rounded-md border">
                    <table class="text-foreground w-full text-sm">
                        <thead class="border-border border-b">
                            <tr class="border-border border-b hover:bg-transparent">
                                <th
                                    class="text-muted-foreground px-3 py-2.5 text-left text-xs font-semibold"
                                    style="width: 64px"
                                >
                                    ID
                                </th>
                                <th class="text-muted-foreground px-3 py-2.5 text-left text-xs font-semibold">
                                    标签
                                </th>
                                <th
                                    class="text-muted-foreground px-3 py-2.5 text-left text-xs font-semibold"
                                    style="width: 180px"
                                >
                                    活动数
                                </th>
                            </tr>
                        </thead>
                        <tbody class="[&>tr:last-child]:border-0">
                            {tags.map((tag) => (
                                <tr class="border-border hover:bg-surface-subtle/60 border-b transition-colors">
                                    <td class="p-3 align-top">{tag.id}</td>
                                    <td class="text-foreground p-3 align-top font-semibold">
                                        {tag.name}
                                    </td>
                                    <td class="p-3 align-top">{tag.event_count}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        )
    }
</AdminLayout>

<script>
    const form = document.querySelector("#merge-tags-form");
    if (form instanceof HTMLFormElement) {
        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            const formData = new FormData(form);
            if (formData.get("from") === formData.get("to")) {
                window.alert("源标签和目标标签不能相同");
                return;
            }

            const confirmed = window.confirm("标签归并不可逆，确认继续？");
            if (!confirmed) return;

            const response = await fetch("/api/admin/tags/merge", {
                method: "POST",
                body: formData
            });

            if (response.ok) {
                window.location.reload();
                return;
            }

            const body = (await response.json().catch(() => null)) as {
                error?: string;
            } | null;
            window.alert(body?.error ?? "归并失败");
        });
    }
</script>
