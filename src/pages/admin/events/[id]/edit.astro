---
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import DivisionPicker from "../../../../components/DivisionPicker.svelte";
import SelectField from "../../../../components/SelectField.svelte";
import { getEvent, listScales, listTypes } from "../../../../lib/db/queries";
import { getDB } from "../../../../lib/db";
import { getRuntimeEnv } from "../../../../lib/runtime/env";

export const prerender = false;

const id = Number.parseInt(Astro.params.id ?? "", 10);
let eventRecord = null;
let types = [];
let scales = [];
let errorMessage = "";

try {
    if (!Number.isInteger(id) || id <= 0) {
        throw new Error("活动 ID 无效");
    }

    const db = await getDB(getRuntimeEnv());
    const [loadedEvent, loadedTypes, loadedScales] = await Promise.all([
        getEvent(db, id),
        listTypes(db),
        listScales(db)
    ]);

    if (!loadedEvent) {
        throw new Error("活动不存在");
    }

    eventRecord = loadedEvent;
    types = loadedTypes;
    scales = loadedScales;
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载活动";
}

const typeOptions = types.map((type) => ({
    value: type.name,
    label: type.label ?? type.name
}));
const scaleOptions = scales.map((scale) => ({
    value: scale.name,
    label: scale.label ?? scale.name
}));
---

<AdminLayout title="编辑活动">
    {
        errorMessage || !eventRecord ? (
            <div class="surface empty-state error-text">{errorMessage}</div>
        ) : (
            <form class="surface form-grid" id="edit-event-form" data-event-id={eventRecord.id}>
                <div class="field wide">
                    <label for="title">活动名称</label>
                    <input id="title" name="title" required value={eventRecord.title} />
                </div>

                <SelectField
                    name="type"
                    label="类型"
                    value={eventRecord.type}
                    options={typeOptions}
                    required
                    client:load
                />

                <SelectField
                    name="scale"
                    label="规模"
                    value={eventRecord.scale}
                    options={scaleOptions}
                    required
                    client:load
                />

                <DivisionPicker
                    name="division_code"
                    value={eventRecord.division_code}
                    label="地区"
                    mode="county"
                    required
                    client:load
                />

                <div class="field">
                    <label for="venue">场馆</label>
                    <input id="venue" name="venue" required value={eventRecord.venue} />
                </div>

                <div class="field wide">
                    <label for="address">地址</label>
                    <input id="address" name="address" value={eventRecord.address ?? ""} />
                </div>

                <div class="field">
                    <label for="start_date">开始日期</label>
                    <input
                        id="start_date"
                        name="start_date"
                        type="date"
                        required
                        value={eventRecord.start_date}
                    />
                </div>

                <div class="field">
                    <label for="end_date">结束日期</label>
                    <input
                        id="end_date"
                        name="end_date"
                        type="date"
                        required
                        value={eventRecord.end_date}
                    />
                </div>

                <div class="field">
                    <label for="source_url">来源链接</label>
                    <input
                        id="source_url"
                        name="source_url"
                        type="url"
                        required
                        value={eventRecord.source_url}
                    />
                </div>

                <div class="field">
                    <label for="submitter_contact">投稿联系方式</label>
                    <input
                        id="submitter_contact"
                        name="submitter_contact"
                        required
                        value={eventRecord.submitter_contact}
                    />
                </div>

                <div class="field">
                    <label for="ticket_url">购票地址</label>
                    <input
                        id="ticket_url"
                        name="ticket_url"
                        type="url"
                        value={eventRecord.ticket_url ?? ""}
                    />
                </div>

                <div class="field">
                    <label for="qq_group">官方交流群</label>
                    <input id="qq_group" name="qq_group" value={eventRecord.qq_group ?? ""} />
                </div>

                <div class="field wide">
                    <label for="cover_url">封面 URL</label>
                    <input
                        id="cover_url"
                        name="cover_url"
                        type="url"
                        value={eventRecord.cover_url ?? ""}
                    />
                </div>

                <div class="field wide">
                    <label for="tags">相关作品标签</label>
                    <input id="tags" name="tags" value={eventRecord.tags ?? ""} />
                </div>

                <div class="field wide">
                    <label for="description">活动说明</label>
                    <textarea id="description" name="description">
                        {eventRecord.description ?? ""}
                    </textarea>
                </div>

                <div class="form-actions">
                    <button class="button button-filled" type="submit">
                        保存
                    </button>
                    <a class="button button-outline" href="/admin/published">
                        返回
                    </a>
                </div>
            </form>
        )
    }
</AdminLayout>

<script>
    const form = document.querySelector("#edit-event-form");
    if (form instanceof HTMLFormElement) {
        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            const eventId = form.dataset.eventId;
            const response = await fetch(`/api/admin/events/${eventId}`, {
                method: "PATCH",
                body: new FormData(form)
            });

            if (response.ok) {
                window.location.assign("/admin/published");
                return;
            }

            const body = (await response.json().catch(() => null)) as {
                error?: string;
            } | null;
            window.alert(body?.error ?? "保存失败");
        });
    }
</script>
