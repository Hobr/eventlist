---
import EventTable from "../../components/admin/EventTable.astro";
import Pagination from "../../components/admin/Pagination.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { listEventsByStatus } from "../../lib/db/queries";
import { getDB, STATUS } from "../../lib/db";
import { getRuntimeEnv } from "../../lib/runtime/env";

export const prerender = false;

const PAGE_SIZE = 25;
const page = Math.max(1, Number.parseInt(Astro.url.searchParams.get("page") ?? "1", 10) || 1);
let events = [];
let errorMessage = "";

try {
    const db = await getDB(getRuntimeEnv());
    events = await listEventsByStatus(db, STATUS.OFFLINE, page, PAGE_SIZE + 1);
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载已下线活动";
}

const hasNext = events.length > PAGE_SIZE;
events = events.slice(0, PAGE_SIZE);
---

<AdminLayout title="已下线活动" description="查看历史记录，并按需修订或重新发布。">
    {
        errorMessage ? (
            <div class="border-border bg-surface text-danger rounded-md border p-6 text-center text-sm font-semibold">
                {errorMessage}
            </div>
        ) : (
            <div class="flex flex-col gap-4">
                <p class="text-muted-foreground text-sm">本页 {events.length} 条已下线活动</p>
                <EventTable events={events} mode="offline" />
                <Pagination page={page} hasNext={hasNext} />
            </div>
        )
    }
</AdminLayout>
