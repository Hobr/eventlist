---
import CitySelector from "../components/CitySelector.svelte";
import EventCard from "../components/EventCard.astro";
import Layout from "../layouts/Layout.astro";
import { FALLBACK_DIVISION_CODE } from "../lib/divisions";
import { resolveSelectedDivision } from "../lib/geo";
import { getDB } from "../lib/db";
import { listPublishedEvents, listTypes, topTags } from "../lib/db/queries";
import { getRuntimeEnv } from "../lib/runtime/env";

export const prerender = false;

const runtimeEnv = getRuntimeEnv();
const defaultDivisionCode = runtimeEnv.DEFAULT_DIVISION_CODE || FALLBACK_DIVISION_CODE;
let events = [];
let tags = [];
let types = [];
let selectedDivision = null;
let sourceLabel = "默认城市";
let errorMessage = "";

try {
    const db = await getDB(runtimeEnv);
    const resolved = await resolveSelectedDivision(
        Astro.request,
        Astro.url.searchParams,
        defaultDivisionCode
    );
    const [eventPage, loadedTags, loadedTypes] = await Promise.all([
        listPublishedEvents(db, {
            divisionCode: resolved.division.code,
            pageSize: 8,
            sort: "start_asc"
        }),
        topTags(db, 8),
        listTypes(db)
    ]);

    events = eventPage.events;
    tags = loadedTags;
    types = loadedTypes;
    selectedDivision = resolved.division;
    sourceLabel =
        resolved.source === "query"
            ? "手动选择"
            : resolved.source === "cf"
              ? "IP 定位"
              : "默认城市";
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载公共活动";
}

const selectedDivisionCode = selectedDivision?.code ?? defaultDivisionCode;
---

<Layout
    title="ACG 活动目录"
    description="按城市、时间、类型、规模和标签浏览近期 ACG 活动，也可以提交待审核活动。"
>
    <section class="home-console page-section">
        <div class="section-inner home-console-grid">
            <div class="command-panel">
                <div class="command-bar" aria-hidden="true">
                    <span class="material-symbols-rounded">search</span>
                    <span>city / date / tag / type</span>
                </div>
                <p class="section-kicker">EVENTLIST COMMAND</p>
                <h1>把近期 ACG 活动当成一张可筛选的情报表。</h1>
                <p class="command-copy">
                    先锁定城市，再按类型、时间和标签缩小范围。Eventlist
                    只把已审核且未结束的活动推到前台。
                </p>
                <div class="home-city-control">
                    <CitySelector selectedDivisionCode={selectedDivisionCode} client:load />
                    <span class="muted">
                        当前地区：{selectedDivision?.label ?? "北京 / 东城区"} · {sourceLabel}
                    </span>
                </div>
                <div class="button-row">
                    <a class="button button-filled" href={`/events?city=${selectedDivisionCode}`}>
                        <span class="material-symbols-rounded" aria-hidden="true">radar</span>
                        打开活动雷达
                    </a>
                    <a class="button button-outline" href="/submit">
                        <span class="material-symbols-rounded" aria-hidden="true">
                            add_location_alt
                        </span>
                        提交线索
                    </a>
                </div>
            </div>

            <div class="intel-panel">
                <div class="intel-metrics">
                    <div>
                        <strong>{events.length}</strong>
                        <span>本地近期</span>
                    </div>
                    <div>
                        <strong>{types.length}</strong>
                        <span>活动类型</span>
                    </div>
                    <div>
                        <strong>{tags.length}</strong>
                        <span>热门标签</span>
                    </div>
                </div>
                <div class="intel-feed">
                    <div class="mini-section-heading">
                        <p class="section-kicker">LIVE PREVIEW</p>
                        <a href={`/events?city=${selectedDivisionCode}`}>查看全部</a>
                    </div>
                    {
                        errorMessage ? (
                            <div class="notice error">{errorMessage}</div>
                        ) : events.length > 0 ? (
                            events
                                .slice(0, 5)
                                .map((event) => <EventCard event={event} variant="row" />)
                        ) : (
                            <div class="panel empty-state">这个城市暂时没有已发布的近期活动。</div>
                        )
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="page-section route-section">
        <div class="section-inner route-board">
            {
                errorMessage ? (
                    <div class="notice error">{errorMessage}</div>
                ) : (
                    <>
                        <div class="route-card route-card-primary">
                            <p class="section-kicker">WORKFLOW</p>
                            <h2>从城市视图开始，再进入完整筛选台</h2>
                            <p class="supporting-copy">
                                首屏给你快速预览；列表页则保留地区、类型、规模、日期和标签筛选，适合认真规划行程。
                            </p>
                            <div class="button-row">
                                <a
                                    class="button button-tonal"
                                    href={`/events?city=${selectedDivisionCode}`}
                                >
                                    <span class="material-symbols-rounded" aria-hidden="true">
                                        travel_explore
                                    </span>
                                    查看完整列表
                                </a>
                            </div>
                        </div>
                        <div class="route-card">
                            <span class="material-symbols-rounded route-icon" aria-hidden="true">
                                category
                            </span>
                            <h3>按类型扫</h3>
                            <div class="chip-row">
                                {types.slice(0, 5).map((type) => (
                                    <a
                                        class="chip"
                                        data-tone="accent"
                                        href={`/events?type=${type.name}`}
                                    >
                                        {type.label}
                                    </a>
                                ))}
                            </div>
                        </div>
                        <div class="route-card">
                            <span class="material-symbols-rounded route-icon" aria-hidden="true">
                                sell
                            </span>
                            <h3>按标签追</h3>
                            <div class="chip-row">
                                {tags.slice(0, 8).map((tag) => (
                                    <a
                                        class="chip"
                                        href={`/events?tag=${encodeURIComponent(tag.name)}`}
                                    >
                                        {tag.name}
                                    </a>
                                ))}
                            </div>
                        </div>
                        <div class="timeline-preview route-feed">
                            <div>
                                <p class="section-kicker">UPCOMING</p>
                                <h3>
                                    {selectedDivision?.city ?? selectedDivision?.name ?? "本地"}
                                </h3>
                            </div>
                            {events.slice(0, 4).map((event) => (
                                <EventCard event={event} variant="row" />
                            ))}
                        </div>
                    </>
                )
            }
        </div>
    </section>
</Layout>
