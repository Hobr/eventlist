---
import EventCard from "../components/events/EventCard.astro";
import EventFilters from "../components/events/EventFilters";
import HotEventsTabs from "../components/events/HotEventsTabs";
import Layout from "../layouts/Layout.astro";
import { parseEventFilters } from "../lib/event-filters";
import { getWorkerEnv } from "../server/env";
import { listHotEvents } from "../server/events/hotlists";
import {
    listPublicEvents,
    listPublicVocabulary,
} from "../server/events/queries";

const filters = parseEventFilters(Astro.url.searchParams);
const env = getWorkerEnv();
const now = new Date();
const [events, vocabulary, hot3, hot7, hot30] = await Promise.all([
    listPublicEvents(filters, { now }),
    listPublicVocabulary(),
    listHotEvents({ windowDays: 3, now, limit: 5 }),
    listHotEvents({ windowDays: 7, now, limit: 5 }),
    listHotEvents({ windowDays: 30, now, limit: 5 }),
]);
const cities = [...new Set(events.map((event) => event.city))].sort((a, b) =>
    a.localeCompare(b, "zh-CN"),
);
---

<Layout title="ACG 活动目录">
    <main class="min-h-screen bg-[var(--surface)] text-[var(--ink)]">
        <header class="border-b border-[var(--line)] bg-[var(--paper)]">
            <div
                class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-6 sm:px-6 lg:px-8"
            >
                <div
                    class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between"
                >
                    <div>
                        <p class="text-sm font-semibold text-[var(--accent)]">
                            ACG Event Directory
                        </p>
                        <h1
                            class="mt-1 text-3xl font-semibold tracking-normal md:text-4xl"
                        >
                            近期 ACG 活动
                        </h1>
                    </div>
                    <nav
                        class="flex flex-wrap gap-2 text-sm"
                        aria-label="主要入口"
                    >
                        <a class="nav-link" href="/">目录</a>
                        <a class="nav-link" href="/submit">提交活动</a>
                        <a class="nav-link" href="/admin">维护后台</a>
                    </nav>
                </div>
                <EventFilters
                    filters={filters}
                    eventTypes={vocabulary.eventTypes}
                    eventIps={vocabulary.eventIps}
                    scales={vocabulary.scales}
                    cities={cities}
                />
            </div>
        </header>

        <div
            class="mx-auto grid max-w-7xl gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:px-8"
        >
            <section aria-labelledby="event-list-title" class="min-w-0">
                <div class="mb-4 flex items-center justify-between gap-3">
                    <h2 id="event-list-title" class="text-xl font-semibold">
                        活动列表
                    </h2>
                    <span class="text-sm text-[var(--muted)]"
                        >{events.length} 个匹配活动</span
                    >
                </div>

                {
                    events.length ? (
                        <div class="grid gap-3">
                            {events.map((event) => (
                                <EventCard event={event} />
                            ))}
                        </div>
                    ) : (
                        <div class="empty-state">没有匹配近期活动</div>
                    )
                }
            </section>

            <aside class="min-w-0" aria-labelledby="hot-title">
                <div
                    class="sticky top-4 rounded-md border border-[var(--line)] bg-[var(--paper)] p-4"
                >
                    <h2 id="hot-title" class="mb-3 text-xl font-semibold">
                        热门活动
                    </h2>
                    <HotEventsTabs
                        client:load
                        windows={{
                            3: hot3,
                            7: hot7,
                            30: hot30,
                        }}
                    />
                </div>
            </aside>
        </div>
    </main>
</Layout>
