---
import CitySelector from "../components/CitySelector.svelte";
import EventCard from "../components/EventCard.astro";
import Layout from "../layouts/Layout.astro";
import { FALLBACK_DIVISION_CODE } from "../lib/divisions";
import { resolveSelectedDivision } from "../lib/geo";
import { getDB } from "../lib/db";
import { listPublishedEvents, listTypes, topTags } from "../lib/db/queries";
import { getRuntimeEnv } from "../lib/runtime/env";

export const prerender = false;

const runtimeEnv = getRuntimeEnv();
const defaultDivisionCode = runtimeEnv.DEFAULT_DIVISION_CODE || FALLBACK_DIVISION_CODE;
let events = [];
let tags = [];
let types = [];
let selectedDivision = null;
let sourceLabel = "默认城市";
let errorMessage = "";

try {
    const db = await getDB(runtimeEnv);
    const resolved = await resolveSelectedDivision(
        Astro.request,
        Astro.url.searchParams,
        defaultDivisionCode
    );
    const [eventPage, loadedTags, loadedTypes] = await Promise.all([
        listPublishedEvents(db, {
            divisionCode: resolved.division.code,
            pageSize: 8,
            sort: "start_asc"
        }),
        topTags(db, 8),
        listTypes(db)
    ]);

    events = eventPage.events;
    tags = loadedTags;
    types = loadedTypes;
    selectedDivision = resolved.division;
    sourceLabel =
        resolved.source === "query"
            ? "手动选择"
            : resolved.source === "cf"
              ? "IP 定位"
              : "默认城市";
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载活动";
}

const selectedDivisionCode = selectedDivision?.code ?? defaultDivisionCode;
---

<Layout
    title="ACG 活动目录"
    description="按城市、时间、类型、规模和标签浏览近期 ACG 活动，也可以提交待审核活动。"
>
    <section class="flex flex-col gap-6">
        <div class="border-border bg-surface rounded-md border p-6">
            <h1 class="text-foreground text-2xl font-semibold">近期 ACG 活动目录</h1>
            <p class="text-muted-foreground mt-2 text-sm">
                先选择城市，再按类型、时间和标签缩小范围。Eventlist 只展示已审核且未结束的活动。
            </p>
            <div class="mt-4 flex flex-col gap-3">
                <CitySelector selectedDivisionCode={selectedDivisionCode} client:load />
                <span class="text-muted text-xs">
                    当前地区：{selectedDivision?.label ?? "北京 / 东城区"} · {sourceLabel}
                </span>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
                <a
                    href={`/events?city=${selectedDivisionCode}`}
                    class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-10 items-center justify-center gap-2 rounded-md px-4 text-sm font-semibold transition-colors"
                >
                    浏览活动列表
                </a>
                <a
                    href="/submit"
                    class="border-border-strong bg-surface text-foreground hover:bg-surface-subtle inline-flex h-10 items-center justify-center gap-2 rounded-md border px-4 text-sm font-semibold transition-colors"
                >
                    提交活动
                </a>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-3">
            <div class="border-border bg-surface rounded-md border p-4">
                <strong class="text-foreground text-xl font-semibold">{events.length}</strong>
                <span class="text-muted-foreground mt-0.5 block text-xs">本地近期</span>
            </div>
            <div class="border-border bg-surface rounded-md border p-4">
                <strong class="text-foreground text-xl font-semibold">{types.length}</strong>
                <span class="text-muted-foreground mt-0.5 block text-xs">活动类型</span>
            </div>
            <div class="border-border bg-surface rounded-md border p-4">
                <strong class="text-foreground text-xl font-semibold">{tags.length}</strong>
                <span class="text-muted-foreground mt-0.5 block text-xs">热门标签</span>
            </div>
        </div>

        <div class="flex flex-col gap-3">
            <div class="flex items-center justify-between">
                <h2 class="text-foreground text-base font-semibold">近期预览</h2>
                <a
                    href={`/events?city=${selectedDivisionCode}`}
                    class="text-link text-sm underline-offset-2 hover:underline">查看全部</a
                >
            </div>
            {
                errorMessage ? (
                    <div class="bg-danger-subtle text-danger rounded-md border border-transparent p-4 text-sm font-semibold">
                        {errorMessage}
                    </div>
                ) : events.length > 0 ? (
                    <div class="flex flex-col gap-2">
                        {events.slice(0, 5).map((event) => (
                            <EventCard event={event} variant="row" />
                        ))}
                    </div>
                ) : (
                    <div class="border-border bg-surface text-muted rounded-md border p-6 text-center text-sm">
                        这个城市暂时没有已发布的近期活动。
                    </div>
                )
            }
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
            <div class="border-border bg-surface rounded-md border p-4">
                <h3 class="text-foreground text-sm font-semibold">按类型浏览</h3>
                <div class="mt-3 flex flex-wrap gap-1.5">
                    {
                        types.slice(0, 5).map((type) => (
                            <a
                                href={`/events?type=${type.name}`}
                                class="bg-accent-subtle text-accent inline-flex items-center rounded-sm px-2 py-0.5 text-xs font-semibold"
                            >
                                {type.label}
                            </a>
                        ))
                    }
                </div>
            </div>
            <div class="border-border bg-surface rounded-md border p-4">
                <h3 class="text-foreground text-sm font-semibold">按标签浏览</h3>
                <div class="mt-3 flex flex-wrap gap-1.5">
                    {
                        tags.slice(0, 8).map((tag) => (
                            <a
                                href={`/events?tag=${encodeURIComponent(tag.name)}`}
                                class="border-border bg-surface-subtle text-muted-foreground inline-flex items-center rounded-sm border px-2 py-0.5 text-xs font-semibold"
                            >
                                {tag.name}
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>
</Layout>
