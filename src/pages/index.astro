---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import MapPinned from "@lucide/astro/icons/map-pinned";
import CitySelector from "../components/CitySelector.svelte";
import EventCard from "../components/EventCard.astro";
import Layout from "../layouts/Layout.astro";
import { getDB } from "../lib/db";
import { FALLBACK_DIVISION_CODE } from "../lib/divisions";
import { EVENT_TYPES } from "../lib/events/options";
import { resolveSelectedDivision } from "../lib/geo";
import { listPublishedEvents, topTags } from "../lib/db/queries";
import { getRuntimeEnv } from "../lib/runtime/env";

export const prerender = false;

const runtimeEnv = getRuntimeEnv();
const defaultDivisionCode = runtimeEnv.DEFAULT_DIVISION_CODE || FALLBACK_DIVISION_CODE;
let events = [];
let tags = [];
const types = EVENT_TYPES;
let selectedDivision = null;
let sourceLabel = "默认城市";
let errorMessage = "";

try {
    const db = await getDB(runtimeEnv);
    const resolved = await resolveSelectedDivision(
        Astro.request,
        Astro.url.searchParams,
        defaultDivisionCode
    );
    const [eventPage, loadedTags] = await Promise.all([
        listPublishedEvents(db, {
            divisionCode: resolved.division.code,
            pageSize: 8,
            sort: "start_asc"
        }),
        topTags(db, 8)
    ]);

    events = eventPage.events;
    tags = loadedTags;
    selectedDivision = resolved.division;
    sourceLabel =
        resolved.source === "query"
            ? "手动选择"
            : resolved.source === "cf"
              ? "IP 定位"
              : "默认城市";
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载活动";
}

const selectedDivisionCode = selectedDivision?.code ?? defaultDivisionCode;
const featuredEvent = events.find((event) => event.cover_url) ?? events[0];
const upcomingEvents = featuredEvent
    ? events.filter((event) => event.id !== featuredEvent.id).slice(0, 4)
    : [];
---

<Layout
    title="ACG 活动目录"
    description="按城市、时间、类型、规模和标签浏览近期 ACG 活动，也可以提交待审核活动。"
>
    <div class="flex flex-col gap-14 sm:gap-16">
        <section aria-labelledby="home-heading" class="flex flex-col gap-6 sm:gap-8">
            <div
                class="grid gap-6 lg:grid-cols-[minmax(0,0.72fr)_minmax(34rem,1.28fr)] lg:items-end lg:gap-12"
            >
                <header class="max-w-xl">
                    <p class="text-sm font-bold text-primary">
                        {selectedDivision?.label ?? "北京"}
                    </p>
                    <h1
                        id="home-heading"
                        class="mt-3 max-w-[11ch] text-4xl leading-[1.05] font-black tracking-[-0.04em] text-foreground sm:text-5xl lg:text-6xl"
                    >
                        发现附近的 ACG 活动
                    </h1>
                    <p
                        class="mt-4 max-w-md text-sm leading-relaxed text-muted-foreground sm:text-base"
                    >
                        只看已审核、未结束的本地活动。
                    </p>
                    <a
                        href={`/events?city=${selectedDivisionCode}`}
                        class="mt-6 inline-flex h-11 items-center gap-2 rounded-md bg-foreground px-5 text-sm font-bold whitespace-nowrap text-background transition-transform focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none active:scale-[0.98]"
                    >
                        浏览全部活动
                        <ArrowRight class="size-4" aria-hidden="true" />
                    </a>
                </header>

                <div class="rounded-md border border-border bg-surface-subtle p-4 sm:p-5">
                    <CitySelector
                        selectedDivisionCode={selectedDivisionCode}
                        label="浏览地区"
                        client:load
                    />
                    <div class="mt-3 flex items-center gap-2 text-xs text-muted">
                        <MapPinned class="size-4" aria-hidden="true" />
                        当前地区来自{sourceLabel}
                    </div>
                </div>
            </div>

            {
                errorMessage ? (
                    <div
                        class="rounded-md bg-danger-subtle p-5 text-sm font-semibold text-danger"
                        role="alert"
                    >
                        {errorMessage}
                    </div>
                ) : featuredEvent ? (
                    <div class="grid gap-4 lg:grid-cols-[minmax(0,1.7fr)_minmax(19rem,0.8fr)] lg:items-start">
                        <EventCard event={featuredEvent} variant="featured" priority />
                        <aside
                            aria-labelledby="upcoming-heading"
                            class="flex flex-col rounded-md border border-border bg-surface p-5 sm:p-6"
                        >
                            <div class="flex items-end justify-between gap-4 border-b border-border pb-4">
                                <h2
                                    id="upcoming-heading"
                                    class="text-xl font-black tracking-tight text-foreground"
                                >
                                    接下来
                                </h2>
                                <span class="text-right text-xs text-muted">
                                    本地区 {events.length} 场
                                </span>
                            </div>
                            <div class="flex-1">
                                {upcomingEvents.length > 0 ? (
                                    upcomingEvents.map((event) => (
                                        <EventCard event={event} variant="compact" />
                                    ))
                                ) : (
                                    <div class="flex min-h-32 items-center py-6">
                                        <p class="max-w-xs text-sm leading-relaxed text-muted-foreground">
                                            当前地区暂时只有这一场近期活动。新的活动通过审核后会显示在这里。
                                        </p>
                                    </div>
                                )}
                            </div>
                        </aside>
                    </div>
                ) : (
                    <div class="rounded-md border border-border bg-surface px-5 py-12 sm:px-8 sm:py-16">
                        <div class="max-w-lg">
                            <h2 class="text-2xl font-black text-foreground">
                                这个地区还没有近期活动
                            </h2>
                            <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
                                可以切换地区，或提交一条新的活动信息。
                            </p>
                        </div>
                        <div class="mt-6 flex flex-wrap gap-3">
                            <a
                                href="/events"
                                class="inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-bold whitespace-nowrap text-background active:scale-[0.98]"
                            >
                                查看全部地区
                            </a>
                            <a
                                href="/submit"
                                class="inline-flex h-10 items-center rounded-md border border-border-strong bg-surface px-4 text-sm font-bold whitespace-nowrap active:scale-[0.98]"
                            >
                                提交活动
                            </a>
                        </div>
                    </div>
                )
            }
        </section>

        {
            types.length > 0 || tags.length > 0 ? (
                <section aria-labelledby="discover-heading" class="flex flex-col gap-6">
                    <div class="max-w-xl">
                        <h2
                            id="discover-heading"
                            class="text-3xl leading-tight font-black tracking-[-0.03em] text-foreground sm:text-4xl"
                        >
                            按兴趣继续发现
                        </h2>
                        <p class="mt-3 text-sm leading-relaxed text-muted-foreground sm:text-base">
                            从活动类型或热门标签进入完整目录。
                        </p>
                    </div>

                    <div class="grid gap-4 lg:grid-cols-[minmax(0,1.15fr)_minmax(19rem,0.85fr)]">
                        {types.length > 0 ? (
                            <div class="rounded-md bg-primary p-5 text-primary-foreground sm:p-7">
                                <h3 class="text-xl font-black">活动类型</h3>
                                <div class="mt-5 grid grid-cols-2 gap-x-5 sm:grid-cols-4 lg:grid-cols-2">
                                    {types.slice(0, 8).map((type) => (
                                        <a
                                            href={`/events?type=${type.name}`}
                                            class="group flex min-w-0 items-center justify-between gap-3 border-b border-primary-foreground/20 py-3 text-sm font-semibold text-current transition-opacity hover:opacity-75 focus-visible:ring-2 focus-visible:ring-primary-foreground/60 focus-visible:outline-none"
                                        >
                                            <span class="truncate">{type.label}</span>
                                            <ArrowRight
                                                class="size-4 shrink-0 transition-transform group-hover:translate-x-0.5"
                                                aria-hidden="true"
                                            />
                                        </a>
                                    ))}
                                </div>
                            </div>
                        ) : null}

                        {tags.length > 0 ? (
                            <div class="rounded-md border border-border bg-surface-subtle p-5 sm:p-7">
                                <h3 class="text-xl font-black text-foreground">热门标签</h3>
                                <div class="mt-5 flex flex-wrap gap-2">
                                    {tags.slice(0, 8).map((tag) => (
                                        <a
                                            href={`/events?tag=${encodeURIComponent(tag.name)}`}
                                            class="inline-flex min-h-10 items-center rounded-sm border border-border-strong bg-surface px-3 py-2 text-sm font-semibold text-foreground transition-colors hover:border-primary hover:text-primary focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none"
                                        >
                                            {tag.name}
                                        </a>
                                    ))}
                                </div>
                            </div>
                        ) : null}
                    </div>
                </section>
            ) : null
        }
    </div>
</Layout>
