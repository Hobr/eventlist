---
import ArrowRight from "@lucide/svelte/icons/arrow-right";
import MapPinned from "@lucide/svelte/icons/map-pinned";
import CitySelector from "../components/CitySelector.svelte";
import EventCard from "../components/EventCard.astro";
import Layout from "../layouts/Layout.astro";
import { FALLBACK_DIVISION_CODE } from "../lib/divisions";
import { resolveSelectedDivision } from "../lib/geo";
import { getDB } from "../lib/db";
import { listPublishedEvents, listTypes, topTags } from "../lib/db/queries";
import { getRuntimeEnv } from "../lib/runtime/env";

export const prerender = false;

const runtimeEnv = getRuntimeEnv();
const defaultDivisionCode = runtimeEnv.DEFAULT_DIVISION_CODE || FALLBACK_DIVISION_CODE;
let events = [];
let tags = [];
let types = [];
let selectedDivision = null;
let sourceLabel = "默认城市";
let errorMessage = "";

try {
    const db = await getDB(runtimeEnv);
    const resolved = await resolveSelectedDivision(
        Astro.request,
        Astro.url.searchParams,
        defaultDivisionCode
    );
    const [eventPage, loadedTags, loadedTypes] = await Promise.all([
        listPublishedEvents(db, {
            divisionCode: resolved.division.code,
            pageSize: 8,
            sort: "start_asc"
        }),
        topTags(db, 8),
        listTypes(db)
    ]);

    events = eventPage.events;
    tags = loadedTags;
    types = loadedTypes;
    selectedDivision = resolved.division;
    sourceLabel =
        resolved.source === "query"
            ? "手动选择"
            : resolved.source === "cf"
              ? "IP 定位"
              : "默认城市";
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载活动";
}

const selectedDivisionCode = selectedDivision?.code ?? defaultDivisionCode;
const featuredEvent = events.find((event) => event.cover_url) ?? events[0];
const upcomingEvents = featuredEvent
    ? events.filter((event) => event.id !== featuredEvent.id).slice(0, 4)
    : [];
---

<Layout
    title="ACG 活动目录"
    description="按城市、时间、类型、规模和标签浏览近期 ACG 活动，也可以提交待审核活动。"
>
    <div class="flex flex-col gap-10 sm:gap-12">
        <section aria-labelledby="home-heading" class="flex flex-col gap-5">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between lg:gap-8">
                <div class="max-w-2xl">
                    <p class="text-primary text-sm font-bold">
                        {selectedDivision?.label ?? "北京"}
                    </p>
                    <h1
                        id="home-heading"
                        class="text-foreground mt-2 text-3xl leading-tight font-black sm:text-4xl"
                    >
                        近期 ACG 活动
                    </h1>
                    <p class="text-muted-foreground mt-3 max-w-xl text-sm sm:text-base">
                        已审核、未结束的本地活动，按日期直接浏览。
                    </p>
                </div>
                <a
                    href={`/events?city=${selectedDivisionCode}`}
                    class="text-foreground focus-visible:ring-ring/60 inline-flex items-center gap-2 text-sm font-bold focus-visible:ring-2 focus-visible:outline-none"
                >
                    查看完整活动表
                    <ArrowRight class="size-4" aria-hidden="true" />
                </a>
            </div>

            <div
                class="border-border grid gap-4 border-y py-5 lg:grid-cols-[1fr_auto] lg:items-end"
            >
                <CitySelector selectedDivisionCode={selectedDivisionCode} client:load />
                <div class="text-muted flex items-center gap-2 text-xs lg:pb-3">
                    <MapPinned class="size-4" aria-hidden="true" />
                    {sourceLabel}
                </div>
            </div>

            {
                errorMessage ? (
                    <div
                        class="bg-danger-subtle text-danger rounded-md p-5 text-sm font-semibold"
                        role="alert"
                    >
                        {errorMessage}
                    </div>
                ) : featuredEvent ? (
                    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.8fr)_minmax(18rem,1fr)] lg:items-start">
                        <EventCard event={featuredEvent} variant="featured" priority />
                        <aside aria-labelledby="upcoming-heading">
                            <div class="border-border flex items-center justify-between border-b pb-3">
                                <h2
                                    id="upcoming-heading"
                                    class="text-foreground text-base font-bold"
                                >
                                    接下来
                                </h2>
                                <span class="text-muted text-xs">{events.length} 场近期活动</span>
                            </div>
                            <div>
                                {upcomingEvents.length > 0 ? (
                                    upcomingEvents.map((event) => (
                                        <EventCard event={event} variant="compact" />
                                    ))
                                ) : (
                                    <div class="text-muted-foreground py-6 text-sm">
                                        当前地区暂时只有这一场近期活动。
                                    </div>
                                )}
                            </div>
                            <a
                                href={`/events?city=${selectedDivisionCode}`}
                                class="bg-foreground text-background mt-5 inline-flex h-10 w-full items-center justify-center gap-2 rounded-md px-4 text-sm font-bold"
                            >
                                浏览全部活动
                                <ArrowRight class="size-4" aria-hidden="true" />
                            </a>
                        </aside>
                    </div>
                ) : (
                    <div class="border-border border-y py-12 text-center">
                        <h2 class="text-foreground text-xl font-bold">这个地区还没有近期活动</h2>
                        <p class="text-muted-foreground mt-2 text-sm">
                            可以查看其他地区，或提交一条新的活动信息。
                        </p>
                        <div class="mt-5 flex flex-wrap justify-center gap-3">
                            <a
                                href="/events"
                                class="bg-foreground text-background inline-flex h-10 items-center rounded-md px-4 text-sm font-bold"
                            >
                                查看全部地区
                            </a>
                            <a
                                href="/submit"
                                class="border-border-strong inline-flex h-10 items-center rounded-md border px-4 text-sm font-bold"
                            >
                                提交活动
                            </a>
                        </div>
                    </div>
                )
            }
        </section>

        <section class="border-border grid gap-8 border-t pt-8 lg:grid-cols-2">
            <div>
                <h2 class="text-foreground text-lg font-bold">按类型发现</h2>
                <div class="mt-4 flex flex-wrap gap-2">
                    {
                        types.slice(0, 8).map((type) => (
                            <a
                                href={`/events?type=${type.name}`}
                                class="bg-primary-subtle text-primary-subtle-foreground hover:bg-primary hover:text-primary-foreground inline-flex items-center rounded-sm px-3 py-1.5 text-sm font-semibold transition-colors"
                            >
                                {type.label}
                            </a>
                        ))
                    }
                </div>
            </div>
            <div>
                <h2 class="text-foreground text-lg font-bold">热门标签</h2>
                <div class="mt-4 flex flex-wrap gap-2">
                    {
                        tags.slice(0, 8).map((tag) => (
                            <a
                                href={`/events?tag=${encodeURIComponent(tag.name)}`}
                                class="border-border-strong text-muted-foreground hover:border-accent hover:text-accent inline-flex items-center rounded-sm border px-3 py-1.5 text-sm font-semibold transition-colors"
                            >
                                {tag.name}
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>
    </div>
</Layout>
