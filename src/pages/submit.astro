---
import ArrowLeft from "@lucide/astro/icons/arrow-left";
import CircleCheck from "@lucide/astro/icons/circle-check";
import Send from "@lucide/astro/icons/send";
import DivisionPicker from "../components/DivisionPicker.svelte";
import SelectField from "../components/SelectField.svelte";
import SubmissionSection from "../components/SubmissionSection.astro";
import Turnstile from "../components/Turnstile.svelte";
import Layout from "../layouts/Layout.astro";
import { EVENT_SCALES, EVENT_TYPES } from "../lib/events/options";
import { getRuntimeEnv } from "../lib/runtime/env";

export const prerender = false;

const runtimeEnv = getRuntimeEnv();
const sent = Astro.url.searchParams.get("sent") === "1";
const typeOptions = EVENT_TYPES.map((type) => ({
    value: type.name,
    label: type.label
}));
const scaleOptions = EVENT_SCALES.map((scale) => ({
    value: scale.name,
    label: scale.label
}));

const fieldCls =
    "flex h-10 w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-sm text-foreground transition-colors placeholder:text-muted focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40";
const textareaCls =
    "flex min-h-32 w-full resize-y rounded-md border border-border-strong bg-surface px-3 py-2 text-sm text-foreground placeholder:text-muted focus-visible:border-ring focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/40";
const labelCls = "text-sm font-semibold text-muted-foreground";
---

<Layout title="提交活动" description="提交 ACG 活动，进入审核队列后再公开展示。">
    {
        sent ? (
            <section class="border-border mx-auto max-w-2xl border-y py-14 text-center">
                <CircleCheck class="text-accent mx-auto size-10" aria-hidden="true" />
                <h1 class="text-foreground mt-5 text-3xl font-black">活动已进入审核队列</h1>
                <p class="text-muted-foreground mt-3 text-sm">审核通过后会出现在公开活动列表中。</p>
                <div class="mt-6 flex flex-wrap justify-center gap-3">
                    <a
                        href="/events"
                        class="bg-foreground text-background inline-flex h-10 items-center rounded-md px-4 text-sm font-bold"
                    >
                        浏览活动
                    </a>
                    <a
                        href="/submit"
                        class="border-border-strong inline-flex h-10 items-center rounded-md border px-4 text-sm font-bold"
                    >
                        继续提交
                    </a>
                </div>
            </section>
        ) : (
            <div class="mx-auto max-w-4xl">
                <header class="border-border border-b pb-7">
                    <p class="text-primary text-sm font-bold">提交至审核队列</p>
                    <h1 class="text-foreground mt-2 text-3xl font-black sm:text-4xl">提交活动</h1>
                    <p class="text-muted-foreground mt-3 max-w-2xl text-sm sm:text-base">
                        必填信息保持可见；封面、描述、交流群和购票信息可按需补充。
                    </p>
                </header>

                <form
                    id="submit-form"
                    class="mt-8 flex flex-col gap-8"
                    action="/api/submit"
                    method="post"
                >
                    <SubmissionSection title="活动基本信息">
                        <div class="grid gap-4 sm:grid-cols-2">
                            <label for="title" class="flex flex-col gap-1.5 sm:col-span-2">
                                <span class={labelCls}>标题</span>
                                <input
                                    id="title"
                                    name="title"
                                    required
                                    maxlength="120"
                                    class={fieldCls}
                                />
                            </label>
                            <SelectField
                                name="type"
                                label="类型"
                                options={typeOptions}
                                placeholder="选择类型"
                                required
                                client:load
                            />
                            <SelectField
                                name="scale"
                                label="规模"
                                options={scaleOptions}
                                placeholder="选择规模"
                                required
                                client:load
                            />
                        </div>
                    </SubmissionSection>

                    <SubmissionSection title="时间与地点">
                        <div class="grid gap-4 sm:grid-cols-2">
                            <div class="sm:col-span-2">
                                <DivisionPicker
                                    name="division_code"
                                    label="地区"
                                    mode="county"
                                    required
                                    client:load
                                />
                            </div>
                            <label for="venue" class="flex flex-col gap-1.5 sm:col-span-2">
                                <span class={labelCls}>地点</span>
                                <input
                                    id="venue"
                                    name="venue"
                                    required
                                    maxlength="120"
                                    class={fieldCls}
                                />
                            </label>
                            <label for="start-date" class="flex flex-col gap-1.5">
                                <span class={labelCls}>开始日期</span>
                                <input
                                    id="start-date"
                                    type="date"
                                    name="start_date"
                                    required
                                    class={fieldCls}
                                />
                            </label>
                            <label for="end-date" class="flex flex-col gap-1.5">
                                <span class={labelCls}>结束日期</span>
                                <input
                                    id="end-date"
                                    type="date"
                                    name="end_date"
                                    required
                                    class={fieldCls}
                                />
                            </label>
                            <label for="start-time" class="flex flex-col gap-1.5">
                                <span class={labelCls}>开始时间（选填）</span>
                                <input
                                    id="start-time"
                                    type="time"
                                    name="start_time"
                                    class={fieldCls}
                                />
                            </label>
                            <label for="end-time" class="flex flex-col gap-1.5">
                                <span class={labelCls}>结束时间（选填）</span>
                                <input id="end-time" type="time" name="end_time" class={fieldCls} />
                            </label>
                        </div>
                    </SubmissionSection>

                    <SubmissionSection
                        title="补充公开信息"
                        description="这些内容会帮助访客判断是否参加活动。"
                        optional
                    >
                        <div class="grid gap-4 sm:grid-cols-2">
                            <label
                                for="tag-suggestions"
                                class="flex flex-col gap-1.5 sm:col-span-2"
                            >
                                <span class={labelCls}>标签描述</span>
                                <textarea
                                    id="tag-suggestions"
                                    name="tag_suggestions"
                                    maxlength="240"
                                    placeholder="例如：东方 Project、同人展、舞台表演；管理员会整理为统一标签"
                                    class={`${textareaCls} min-h-24`}
                                />
                                <span class="text-muted text-xs">
                                    这里只需大概描述，正式标签会在审核时统一整理。
                                </span>
                            </label>
                            <label for="address" class="flex flex-col gap-1.5 sm:col-span-2">
                                <span class={labelCls}>详细地址</span>
                                <input
                                    id="address"
                                    name="address"
                                    maxlength="240"
                                    class={fieldCls}
                                />
                            </label>
                            <label for="cover-url" class="flex flex-col gap-1.5 sm:col-span-2">
                                <span class={labelCls}>封面 URL</span>
                                <input
                                    id="cover-url"
                                    type="url"
                                    name="cover_url"
                                    placeholder="https://..."
                                    class={fieldCls}
                                />
                            </label>
                            <label for="description" class="flex flex-col gap-1.5 sm:col-span-2">
                                <span class={labelCls}>活动描述</span>
                                <textarea
                                    id="description"
                                    name="description"
                                    maxlength="4000"
                                    class={textareaCls}
                                />
                            </label>
                            <label for="qq-group" class="flex flex-col gap-1.5">
                                <span class={labelCls}>官方交流群 QQ</span>
                                <input
                                    id="qq-group"
                                    name="qq_group"
                                    maxlength="80"
                                    class={fieldCls}
                                />
                            </label>
                            <label for="ticket-url" class="flex flex-col gap-1.5">
                                <span class={labelCls}>购票地址</span>
                                <input
                                    id="ticket-url"
                                    type="url"
                                    name="ticket_url"
                                    placeholder="https://..."
                                    class={fieldCls}
                                />
                            </label>
                        </div>
                    </SubmissionSection>

                    <SubmissionSection
                        title="审核与提交"
                        description="联系方式仅用于核对信息，不会在前台公开。"
                    >
                        <div class="grid gap-4 sm:grid-cols-2">
                            <label for="source-url" class="flex flex-col gap-1.5 sm:col-span-2">
                                <span class={labelCls}>活动来源链接</span>
                                <input
                                    id="source-url"
                                    type="url"
                                    name="source_url"
                                    placeholder="https://..."
                                    required
                                    class={fieldCls}
                                />
                            </label>
                            <label
                                for="submitter-contact"
                                class="flex flex-col gap-1.5 sm:col-span-2"
                            >
                                <span class={labelCls}>投稿联系方式</span>
                                <input
                                    id="submitter-contact"
                                    name="submitter_contact"
                                    required
                                    maxlength="120"
                                    class={fieldCls}
                                />
                            </label>
                            <div class="sm:col-span-2">
                                <Turnstile siteKey={runtimeEnv.TURNSTILE_SITE_KEY} client:load />
                            </div>
                            <p
                                id="submit-result"
                                class="text-danger hidden text-sm font-semibold sm:col-span-2"
                                role="status"
                                tabindex="-1"
                            />
                            <div class="border-border flex flex-wrap gap-3 border-t pt-5 sm:col-span-2">
                                <button
                                    id="submit-button"
                                    class="bg-primary text-primary-foreground inline-flex h-11 items-center justify-center gap-2 rounded-md px-5 text-sm font-bold disabled:pointer-events-none disabled:opacity-60"
                                    type="submit"
                                >
                                    <Send class="size-4" aria-hidden="true" />
                                    提交审核
                                </button>
                                <a
                                    class="border-border-strong text-foreground inline-flex h-11 items-center justify-center gap-2 rounded-md border px-5 text-sm font-bold"
                                    href="/events"
                                >
                                    <ArrowLeft class="size-4" aria-hidden="true" />
                                    返回活动列表
                                </a>
                            </div>
                        </div>
                    </SubmissionSection>
                </form>
            </div>
        )
    }
</Layout>

<script>
    const form = document.querySelector("#submit-form");
    const result = document.querySelector("#submit-result");
    const submitButton = document.querySelector("#submit-button");

    if (form instanceof HTMLFormElement && result instanceof HTMLElement) {
        form.addEventListener(
            "invalid",
            (event) => {
                const target = event.target;
                if (!(target instanceof HTMLElement)) return;
                const disclosure = target.closest("details");
                if (disclosure instanceof HTMLDetailsElement) disclosure.open = true;
            },
            true
        );

        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            result.classList.add("hidden");

            if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;

            try {
                const response = await fetch(form.action, {
                    method: "POST",
                    body: new FormData(form)
                });

                if (response.ok) {
                    window.location.assign("/submit?sent=1");
                    return;
                }

                const body = (await response.json().catch(() => null)) as {
                    error?: string;
                } | null;
                result.textContent = body?.error ?? "提交失败";
                result.classList.remove("hidden");
                result.focus();
            } catch {
                result.textContent = "网络连接失败，请稍后重试";
                result.classList.remove("hidden");
                result.focus();
            } finally {
                if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
            }
        });
    }
</script>
