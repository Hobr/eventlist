---
import TagInput from "../components/TagInput.svelte";
import Turnstile from "../components/Turnstile.svelte";
import Layout from "../layouts/Layout.astro";
import { getDB } from "../lib/db";
import { listCities, listScales, listTypes } from "../lib/db/queries";
import { getRuntimeEnv } from "../lib/runtime/env";

export const prerender = false;

const runtimeEnv = getRuntimeEnv();
const sent = Astro.url.searchParams.get("sent") === "1";
let cities = [];
let types = [];
let scales = [];
let errorMessage = "";

try {
    const db = await getDB(runtimeEnv);
    [cities, types, scales] = await Promise.all([
        listCities(db),
        listTypes(db),
        listScales(db),
    ]);
} catch (error) {
    errorMessage = error instanceof Error ? error.message : "无法加载投稿表单";
}
---

<Layout
    title="提交活动"
    description="提交 ACG 活动，进入审核队列后再公开展示。"
>
    <section class="page-section">
        <div class="section-inner">
            <div class="page-heading">
                <p class="section-kicker">SUBMIT</p>
                <h1>提交活动</h1>
                <p class="supporting-copy">
                    投稿会先进入待审核队列；联系方式仅用于核对信息，不会在前台公开。
                </p>
            </div>

            {
                sent ? (
                    <div class="notice">
                        投稿已进入审核队列，审核通过后会出现在公共列表中。
                    </div>
                ) : errorMessage ? (
                    <div class="notice error">{errorMessage}</div>
                ) : (
                    <form
                        id="submit-form"
                        class="panel form-grid"
                        method="POST"
                        action="/api/submit"
                    >
                        <label class="field wide">
                            <span>标题</span>
                            <input name="title" required maxlength="120" />
                        </label>

                        <label class="field">
                            <span>类型</span>
                            <select name="type" required>
                                {types.map((type) => (
                                    <option value={type.name}>
                                        {type.label ?? type.name}
                                    </option>
                                ))}
                            </select>
                        </label>

                        <label class="field">
                            <span>规模</span>
                            <select name="scale" required>
                                {scales.map((scale) => (
                                    <option value={scale.name}>
                                        {scale.label ?? scale.name}
                                    </option>
                                ))}
                            </select>
                        </label>

                        <label class="field">
                            <span>城市</span>
                            <select name="city_id" required>
                                {cities.map((city) => (
                                    <option value={city.id}>
                                        {city.name}
                                        {city.province
                                            ? ` / ${city.province}`
                                            : ""}
                                    </option>
                                ))}
                            </select>
                        </label>

                        <label class="field">
                            <span>地点</span>
                            <input name="venue" required maxlength="120" />
                        </label>

                        <label class="field wide">
                            <span>地址</span>
                            <input name="address" maxlength="240" />
                        </label>

                        <label class="field">
                            <span>开始日期</span>
                            <input type="date" name="start_date" required />
                        </label>

                        <label class="field">
                            <span>结束日期</span>
                            <input type="date" name="end_date" required />
                        </label>

                        <label class="field wide">
                            <span>封面 URL</span>
                            <input
                                type="url"
                                name="cover_url"
                                placeholder="https://..."
                            />
                        </label>

                        <label class="field wide">
                            <span>描述</span>
                            <textarea name="description" maxlength="4000" />
                        </label>

                        <TagInput client:load />

                        <label class="field">
                            <span>官方交流群 QQ</span>
                            <input name="qq_group" maxlength="80" />
                        </label>

                        <label class="field">
                            <span>购票地址</span>
                            <input
                                type="url"
                                name="ticket_url"
                                placeholder="https://..."
                            />
                        </label>

                        <label class="field wide">
                            <span>来源链接</span>
                            <input
                                type="url"
                                name="source_url"
                                placeholder="https://..."
                                required
                            />
                        </label>

                        <label class="field wide">
                            <span>联系方式</span>
                            <input
                                name="submitter_contact"
                                required
                                maxlength="120"
                            />
                        </label>

                        <Turnstile
                            siteKey={runtimeEnv.TURNSTILE_SITE_KEY}
                            client:load
                        />

                        <p
                            id="submit-result"
                            class="submit-result error-text hidden"
                            role="status"
                        />

                        <div class="button-row wide">
                            <button class="button button-filled" type="submit">
                                <span
                                    class="material-symbols-rounded"
                                    aria-hidden="true"
                                >
                                    send
                                </span>
                                提交审核
                            </button>
                            <a class="button button-outline" href="/events">
                                返回列表
                            </a>
                        </div>
                    </form>
                )
            }
        </div>
    </section>
</Layout>

<script>
    const form = document.querySelector("#submit-form");
    const result = document.querySelector("#submit-result");

    if (form instanceof HTMLFormElement && result instanceof HTMLElement) {
        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            result.classList.add("hidden");

            const response = await fetch(form.action, {
                method: "POST",
                body: new FormData(form),
            });

            if (response.ok) {
                window.location.assign("/submit?sent=1");
                return;
            }

            const body = (await response.json().catch(() => null)) as {
                error?: string;
            } | null;
            result.textContent = body?.error ?? "提交失败";
            result.classList.remove("hidden");
        });
    }
</script>
