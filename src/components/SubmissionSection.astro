---
import ChevronDown from "@lucide/astro/icons/chevron-down";

interface Props {
    title: string;
    description?: string;
    optional?: boolean;
}

const { title, description, optional = false } = Astro.props;
---

{
    optional ? (
        <details class="group border-y border-border py-5" data-form-disclosure>
            <summary class="flex cursor-pointer items-center justify-between gap-4 rounded-sm focus-visible:ring-2 focus-visible:ring-ring/60 focus-visible:outline-none">
                <span>
                    <strong class="block text-base font-bold text-foreground">{title}</strong>
                    {description ? (
                        <span class="mt-1 block text-sm text-muted-foreground">{description}</span>
                    ) : null}
                </span>
                <span class="inline-flex shrink-0 items-center gap-2 text-xs font-semibold text-muted">
                    选填
                    <ChevronDown
                        class="size-4 transition-transform group-open:rotate-180"
                        aria-hidden="true"
                    />
                </span>
            </summary>
            <div class="pt-6">
                <slot />
            </div>
        </details>
    ) : (
        <fieldset class="border-t border-border pt-6">
            <legend class="pr-4 text-base font-bold text-foreground">{title}</legend>
            {description ? <p class="mt-1 text-sm text-muted-foreground">{description}</p> : null}
            <div class="mt-5">
                <slot />
            </div>
        </fieldset>
    )
}
