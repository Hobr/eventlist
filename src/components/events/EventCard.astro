---
import type { PublicEvent } from "../../server/events/types";
import { formatDateRange } from "../../server/events/utils";

interface Props {
    event: PublicEvent;
}

const { event } = Astro.props;
---

<article class="event-card">
    <a
        class="event-card__media"
        href={`/events/${event.slug}`}
        aria-label={`查看 ${event.name}`}
    >
        {
            event.cover?.publicUrl ? (
                <img src={event.cover.publicUrl} alt="" loading="lazy" />
            ) : (
                <span>{event.city.slice(0, 2)}</span>
            )
        }
    </a>
    <div class="min-w-0 flex-1">
        <div class="mb-2 flex flex-wrap gap-2">
            <span class="pill"
                >{formatDateRange(event.startsAt, event.endsAt)}</span
            >
            {
                event.scale && (
                    <span class="pill pill-strong">{event.scale.name}</span>
                )
            }
            {event.isEnded && <span class="pill">已结束</span>}
        </div>
        <h3 class="text-lg leading-snug font-semibold">
            <a class="focus-link line-clamp-2" href={`/events/${event.slug}`}
                >{event.name}</a
            >
        </h3>
        <p class="mt-2 text-sm break-words text-[var(--muted)]">
            {event.city} / {event.venue}
        </p>
        <div class="mt-3 flex flex-wrap gap-2 text-sm">
            {event.type && <span class="tag">{event.type.name}</span>}
            {event.eventIp && <span class="tag">{event.eventIp.name}</span>}
        </div>
    </div>
    <a class="button-ghost self-start" href={`/events/${event.slug}`}>详情</a>
</article>
