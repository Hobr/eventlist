---
import Button from "../../components/ui/button.svelte";

interface Props {
    page: number;
    hasNext: boolean;
}

const { page, hasNext } = Astro.props;

function hrefFor(nextPage: number) {
    const url = new URL(Astro.url);
    url.searchParams.set("page", String(nextPage));
    return `${url.pathname}${url.search}`;
}
---

<nav class="flex items-center justify-center gap-3 py-4 text-sm text-muted" aria-label="分页">
    {
        page > 1 ? (
            <Button variant="outline" size="sm" href={hrefFor(page - 1)}>
                上一页
            </Button>
        ) : null
    }
    <span class="font-medium text-muted-foreground">第 {page} 页</span>
    {
        hasNext ? (
            <Button variant="outline" size="sm" href={hrefFor(page + 1)}>
                下一页
            </Button>
        ) : null
    }
</nav>
