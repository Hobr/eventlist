---
interface Props {
    page: number;
    hasNext: boolean;
}

const { page, hasNext } = Astro.props;

function hrefFor(nextPage: number) {
    const url = new URL(Astro.url);
    url.searchParams.set("page", String(nextPage));
    return `${url.pathname}${url.search}`;
}
---

<nav class="pagination" aria-label="分页">
    {page > 1 ? <a class="button button-outline" href={hrefFor(page - 1)}>上一页</a> : <span />}
    <span class="pagination-current">第 {page} 页</span>
    {hasNext ? <a class="button button-outline" href={hrefFor(page + 1)}>下一页</a> : <span />}
</nav>
