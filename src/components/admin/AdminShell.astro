---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<div class="admin-shell">
    <aside class="admin-nav">
        <a class="focus-link mb-4 inline-flex font-semibold" href="/"
            >ACG 活动目录</a
        >
        <nav class="grid gap-2 text-sm" aria-label="后台导航">
            <a class="nav-link" href="/admin">审核队列</a>
            <a class="nav-link" href="/admin/vocabularies">词表</a>
            <a class="nav-link" href="/admin/scales">规模标签</a>
        </nav>
    </aside>
    <main class="admin-main">
        <header class="mb-4">
            <h1 class="text-2xl font-semibold">{title}</h1>
        </header>
        <slot />
    </main>
</div>
