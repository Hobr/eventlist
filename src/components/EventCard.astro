---
import type { EventRecord } from "../lib/db/queries";
import { getDivisionLabel } from "../lib/divisions";
import Badge from "./ui/badge.svelte";

interface Props {
    event: EventRecord;
    variant?: "card" | "row";
}

const { event, variant = "card" } = Astro.props;
const tags = event.tags ? event.tags.split("、").filter(Boolean).slice(0, 4) : [];
const coverUrl = event.cover_url || "";
const divisionLabel = getDivisionLabel(event.division_code);
const startLabel = event.start_date.slice(5).replace("-", "/");
const endLabel = event.end_date.slice(5).replace("-", "/");
---

<a
    href={`/events/${event.id}`}
    class:list={[
        "group border-border bg-surface hover:bg-surface-subtle/60 focus-visible:border-ring focus-visible:ring-ring/40 flex gap-4 rounded-md border p-4 transition-colors focus-visible:ring-2 focus-visible:outline-none",
        variant === "row" ? "flex-row items-center" : "flex-col gap-3"
    ]}
>
    {
        variant === "row" ? (
            <div class="flex w-20 shrink-0 flex-col text-center">
                <strong class="text-foreground text-sm font-semibold">{startLabel}</strong>
                <span class="text-muted text-xs">至 {endLabel}</span>
            </div>
        ) : coverUrl ? (
            <img
                src={coverUrl}
                alt={`${event.title} 封面`}
                loading="lazy"
                class="aspect-[4/3] w-full rounded-sm object-cover"
            />
        ) : (
            <div class="bg-surface-subtle aspect-[4/3] w-full rounded-sm" />
        )
    }

    <div class="flex min-w-0 flex-1 flex-col gap-2">
        <div class="flex flex-wrap items-center gap-1.5">
            <Badge tone="accent">{event.type_label ?? event.type}</Badge>
            <Badge>{event.scale_label ?? event.scale}</Badge>
        </div>
        <h3 class="text-foreground text-base leading-tight font-semibold">{event.title}</h3>
        <div class="text-muted-foreground flex flex-col gap-1 text-sm">
            <span>{event.start_date} - {event.end_date}</span>
            <span>{divisionLabel ?? "未知地区"} · {event.venue}</span>
        </div>
        {
            tags.length > 0 ? (
                <div class="flex flex-wrap gap-1.5">
                    {tags.map((tag) => (
                        <Badge>{tag}</Badge>
                    ))}
                </div>
            ) : null
        }
    </div>
</a>
