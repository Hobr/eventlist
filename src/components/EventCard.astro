---
import CalendarDays from "@lucide/astro/icons/calendar-days";
import MapPin from "@lucide/astro/icons/map-pin";
import ArrowUpRight from "@lucide/astro/icons/arrow-up-right";
import type { EventRecord } from "../lib/db/queries";
import { getDivisionLabel } from "../lib/divisions";
import { formatEventSchedule } from "../lib/events/datetime";
import Badge from "./ui/badge.svelte";
import EventArtwork from "./EventArtwork.astro";

interface Props {
    event: EventRecord;
    variant?: "card" | "row" | "featured" | "compact";
    priority?: boolean;
}

const { event, variant = "card", priority = false } = Astro.props;
const tags = event.tags ? event.tags.split("、").filter(Boolean).slice(0, 3) : [];
const divisionLabel = getDivisionLabel(event.division_code) ?? "未知地区";
const startLabel = `${event.start_date.slice(5).replace("-", "/")}${event.start_time ? ` ${event.start_time}` : ""}`;
const endLabel = `${event.end_date.slice(5).replace("-", "/")}${event.end_time ? ` ${event.end_time}` : ""}`;
const dateLabel = formatEventSchedule(event);
const href = `/events/${event.id}`;
---

{
    variant === "featured" ? (
        <a
            href={href}
            class="group focus-visible:ring-ring/70 bg-foreground relative block min-h-[23rem] overflow-hidden rounded-md text-zinc-50 transition-transform focus-visible:ring-2 focus-visible:outline-none active:scale-[0.995] sm:min-h-[28rem]"
        >
            <EventArtwork
                src={event.cover_url}
                alt={`${event.title} 封面`}
                loading={priority ? "eager" : "lazy"}
                fill
                class="rounded-none transition-transform duration-300 group-hover:scale-[1.02]"
            />
            <div
                class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,8,12,0.08)_20%,rgba(10,8,12,0.88)_100%)]"
                aria-hidden="true"
            />
            <div class="absolute inset-x-0 bottom-0 p-5 sm:p-7 lg:p-8">
                <p class="mb-3 text-xs font-bold text-zinc-50/80 sm:text-sm">
                    {event.type_label ?? event.type} / {event.scale_label ?? event.scale}
                </p>
                <h2 class="max-w-3xl text-2xl leading-tight font-black tracking-[-0.025em] sm:text-4xl">
                    {event.title}
                </h2>
                <div class="mt-4 flex flex-col gap-2 text-sm text-zinc-50/85 sm:flex-row sm:flex-wrap sm:gap-x-5">
                    <span class="inline-flex items-center gap-2">
                        <CalendarDays class="size-4" aria-hidden="true" />
                        {dateLabel}
                    </span>
                    <span class="inline-flex items-center gap-2">
                        <MapPin class="size-4" aria-hidden="true" />
                        {divisionLabel} · {event.venue}
                    </span>
                </div>
                <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold">
                    查看活动
                    <ArrowUpRight
                        class="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                        aria-hidden="true"
                    />
                </span>
            </div>
        </a>
    ) : variant === "compact" ? (
        <a
            href={href}
            class="group border-border focus-visible:ring-ring/60 hover:text-primary grid grid-cols-[4.25rem_minmax(0,1fr)_auto] items-center gap-3 border-b py-4 transition-colors focus-visible:ring-2 focus-visible:outline-none"
        >
            <div class="flex flex-col">
                <strong class="text-primary text-lg leading-none font-black">{startLabel}</strong>
                <span class="text-muted mt-1 text-xs">至 {endLabel}</span>
            </div>
            <div class="min-w-0">
                <h3 class="text-foreground group-hover:text-primary truncate text-sm font-bold transition-colors sm:text-base">
                    {event.title}
                </h3>
                <p class="text-muted-foreground mt-1 truncate text-xs sm:text-sm">
                    {divisionLabel} · {event.venue}
                </p>
            </div>
            <ArrowUpRight
                class="text-muted size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                aria-hidden="true"
            />
        </a>
    ) : variant === "row" ? (
        <a
            href={href}
            class="group border-border focus-visible:ring-ring/60 grid min-w-0 grid-cols-[6.5rem_minmax(0,1fr)] gap-4 border-b py-4 focus-visible:ring-2 focus-visible:outline-none sm:grid-cols-[9rem_minmax(0,1fr)_auto] sm:items-center"
        >
            <EventArtwork
                src={event.cover_url}
                alt={`${event.title} 封面`}
                class="aspect-[4/3] w-full"
            />
            <div class="min-w-0">
                <div class="mb-2 flex flex-wrap gap-1.5">
                    <Badge tone="primary">{event.type_label ?? event.type}</Badge>
                    <Badge>{event.scale_label ?? event.scale}</Badge>
                </div>
                <h3 class="text-foreground text-base leading-tight font-bold sm:text-lg">
                    {event.title}
                </h3>
                <div class="text-muted-foreground mt-2 flex flex-col gap-1 text-xs sm:flex-row sm:flex-wrap sm:gap-x-4 sm:text-sm">
                    <span class="inline-flex items-center gap-1.5">
                        <CalendarDays class="size-3.5" aria-hidden="true" />
                        {dateLabel}
                    </span>
                    <span class="inline-flex min-w-0 items-center gap-1.5">
                        <MapPin class="size-3.5 shrink-0" aria-hidden="true" />
                        <span class="truncate">
                            {divisionLabel} · {event.venue}
                        </span>
                    </span>
                </div>
                {tags.length > 0 ? (
                    <div class="mt-3 hidden flex-wrap gap-1.5 sm:flex">
                        {tags.map((tag) => (
                            <Badge>{tag}</Badge>
                        ))}
                    </div>
                ) : null}
            </div>
            <ArrowUpRight
                class="text-muted hidden size-5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 sm:block"
                aria-hidden="true"
            />
        </a>
    ) : (
        <a
            href={href}
            class="group border-border bg-surface focus-visible:ring-ring/60 flex flex-col overflow-hidden rounded-md border focus-visible:ring-2 focus-visible:outline-none"
        >
            <EventArtwork
                src={event.cover_url}
                alt={`${event.title} 封面`}
                class="aspect-[4/3] rounded-none"
            />
            <div class="flex flex-1 flex-col p-4">
                <div class="flex flex-wrap gap-1.5">
                    <Badge tone="primary">{event.type_label ?? event.type}</Badge>
                    <Badge>{event.scale_label ?? event.scale}</Badge>
                </div>
                <h3 class="text-foreground mt-3 text-base leading-tight font-bold">
                    {event.title}
                </h3>
                <p class="text-muted-foreground mt-3 text-sm">{dateLabel}</p>
                <p class="text-muted mt-1 text-xs">
                    {divisionLabel} · {event.venue}
                </p>
            </div>
        </a>
    )
}
