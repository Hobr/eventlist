---
import type { EventRecord } from "../lib/db/queries";
import { getDivisionLabel } from "../lib/divisions";

interface Props {
    event: EventRecord;
    variant?: "card" | "row";
}

const { event, variant = "card" } = Astro.props;
const tags = event.tags ? event.tags.split("、").filter(Boolean).slice(0, 4) : [];
const coverUrl = event.cover_url || "";
const divisionLabel = getDivisionLabel(event.division_code);
const startLabel = event.start_date.slice(5).replace("-", "/");
const endLabel = event.end_date.slice(5).replace("-", "/");
---

<a class:list={["event-card", variant === "row" && "event-row"]} href={`/events/${event.id}`}>
    {
        variant === "row" ? (
            <div class="event-row-date" aria-label={`${event.start_date} 至 ${event.end_date}`}>
                <strong>{startLabel}</strong>
                <span>{endLabel}</span>
            </div>
        ) : coverUrl ? (
            <img class="event-cover" src={coverUrl} alt={`${event.title} 封面`} loading="lazy" />
        ) : (
            <div class="event-cover" aria-hidden="true" />
        )
    }
    <div class="event-card-body">
        <div class="chip-row">
            <span class="chip" data-tone="accent">{event.type_label ?? event.type}</span>
            <span class="chip">{event.scale_label ?? event.scale}</span>
        </div>
        <h3>{event.title}</h3>
        <div class="event-meta">
            <div class="event-meta-line">
                <span class="material-symbols-rounded" aria-hidden="true">calendar_month</span>
                <span>{event.start_date} - {event.end_date}</span>
            </div>
            <div class="event-meta-line">
                <span class="material-symbols-rounded" aria-hidden="true">location_on</span>
                <span>{divisionLabel ?? "未知地区"} · {event.venue}</span>
            </div>
        </div>
        {
            tags.length > 0 ? (
                <div class="chip-row event-tags">
                    {tags.map((tag) => (
                        <span class="chip">{tag}</span>
                    ))}
                </div>
            ) : null
        }
    </div>
    {
        variant === "row" ? (
            <span class="material-symbols-rounded event-row-arrow" aria-hidden="true">
                arrow_forward
            </span>
        ) : null
    }
</a>
