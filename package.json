{
  "name": "acg-events",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev -c dist/server/wrangler.json",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply acg-events --local",
    "db:migrate:prod": "wrangler d1 migrations apply acg-events --remote",
    "db:seed:local": "wrangler d1 execute acg-events --local --file seeds/demo.sql",
    "cf-typegen": "wrangler types",
    "deploy": "astro build && wrangler deploy -c dist/server/wrangler.json"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/react": "^5.0.6",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^6.4.2",
    "browser-image-compression": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260601.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.96.0"
  }
}
