{
    "name": "eventlist",
    "type": "module",
    "version": "0.0.1",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro build && astro preview",
        "astro": "astro",
        "generate-types": "wrangler types",
        "deploy": "astro build && wrangler deploy",
        "cf-typegen": "wrangler types",
        "db:migrate:local": "wrangler d1 migrations apply eventlist-db --local",
        "db:migrate:remote": "wrangler d1 migrations apply eventlist-db --remote",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write .",
        "seed": "tsx scripts/seed-events.ts",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@astrojs/cloudflare": "^13.6.1",
        "@astrojs/react": "^5.0.7",
        "@tailwindcss/vite": "^4.3.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "astro": "^6.4.6",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "fuse.js": "^7.4.2",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tailwindcss": "^4.3.0"
    },
    "devDependencies": {
        "@typescript-eslint/parser": "^8.61.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.7.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "prettier": "3.8.3",
        "prettier-plugin-astro": "0.14.1",
        "prettier-plugin-tailwindcss": "0.8.0",
        "tsx": "^4.22.4",
        "vitest": "^4.1.8",
        "wrangler": "^4.98.0"
    },
    "overrides": {
        "vite": "^7"
    }
}
